"rootdir: $REGENDOC_TMPDIR, inifile:\n"
"collected 2 items\n"
"\n"
"test_module.py FF\n"
"\n"
"======= FAILURES ========\n"
"_______ test_fail1 ________\n"
"\n"
"tmpdir = local('PYTEST_TMPDIR/test_fail10')\n"
"\n"
"    def test_fail1(tmpdir):\n"
">       assert 0\n"
"E       assert 0\n"
"\n"
"test_module.py:2: AssertionError\n"
