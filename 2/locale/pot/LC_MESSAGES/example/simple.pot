#: ../../../doc/en/example/simple.rst:3
msgid "Basic patterns and examples"
msgstr ""

#: ../../../doc/en/example/simple.rst:6
msgid ""
"Pass different values to a test function, depending on command line options"
msgstr ""

#: ../../../doc/en/example/simple.rst:10
msgid ""
"Suppose we want to write a test that depends on a command line option. Here "
"is a basic pattern to achieve this:"
msgstr ""

#: ../../../doc/en/example/simple.rst:13
msgid ""
"# content of test_sample.py\n"
"def test_answer(cmdopt):\n"
"    if cmdopt == \"type1\":\n"
"        print (\"first\")\n"
"    elif cmdopt == \"type2\":\n"
"        print (\"second\")\n"
"    assert 0 # to see what was printed"
msgstr ""

#: ../../../doc/en/example/simple.rst:24
msgid ""
"For this to work we need to add a command line option and provide the "
"``cmdopt`` through a :ref:`fixture function <fixture function>`:"
msgstr ""

#: ../../../doc/en/example/simple.rst:27
msgid ""
"# content of conftest.py\n"
"import pytest\n"
"\n"
"def pytest_addoption(parser):\n"
"    parser.addoption(\"--cmdopt\", action=\"store\", default=\"type1\",\n"
"        help=\"my option: type1 or type2\")\n"
"\n"
"@pytest.fixture\n"
"def cmdopt(request):\n"
"    return request.config.getoption(\"--cmdopt\")"
msgstr ""

#: ../../../doc/en/example/simple.rst:40
msgid "Let's run this without supplying our new option::"
msgstr ""

#: ../../../doc/en/example/simple.rst:42
msgid ""
"$ py.test -q test_sample.py\n"
"F\n"
"======= FAILURES ========\n"
"_______ test_answer ________\n"
"\n"
"cmdopt = 'type1'\n"
"\n"
"    def test_answer(cmdopt):\n"
"        if cmdopt == \"type1\":\n"
"            print (\"first\")\n"
"        elif cmdopt == \"type2\":\n"
"            print (\"second\")\n"
">       assert 0 # to see what was printed\n"
"E       assert 0\n"
"\n"
"test_sample.py:6: AssertionError\n"
"--------------------------- Captured stdout call "
"---------------------------\n"
"first\n"
"1 failed in 0.12 seconds"
msgstr ""

#: ../../../doc/en/example/simple.rst:62
msgid "And now with supplying a command line option::"
msgstr ""

#: ../../../doc/en/example/simple.rst:64
msgid ""
"$ py.test -q --cmdopt=type2\n"
"F\n"
"======= FAILURES ========\n"
"_______ test_answer ________\n"
"\n"
"cmdopt = 'type2'\n"
"\n"
"    def test_answer(cmdopt):\n"
"        if cmdopt == \"type1\":\n"
"            print (\"first\")\n"
"        elif cmdopt == \"type2\":\n"
"            print (\"second\")\n"
">       assert 0 # to see what was printed\n"
"E       assert 0\n"
"\n"
"test_sample.py:6: AssertionError\n"
"--------------------------- Captured stdout call "
"---------------------------\n"
"second\n"
"1 failed in 0.12 seconds"
msgstr ""

#: ../../../doc/en/example/simple.rst:84
msgid ""
"You can see that the command line option arrived in our test.  This "
"completes the basic pattern.  However, one often rather wants to process "
"command line options outside of the test and rather pass in different or "
"more complex objects."
msgstr ""

#: ../../../doc/en/example/simple.rst:90
msgid "Dynamically adding command line options"
msgstr ""

#: ../../../doc/en/example/simple.rst:94
msgid ""
"Through :confval:`addopts` you can statically add command line options for "
"your project.  You can also dynamically modify the command line arguments "
"before they get processed:"
msgstr ""

#: ../../../doc/en/example/simple.rst:98
msgid ""
"# content of conftest.py\n"
"import sys\n"
"def pytest_cmdline_preparse(args):\n"
"    if 'xdist' in sys.modules: # pytest-xdist plugin\n"
"        import multiprocessing\n"
"        num = max(multiprocessing.cpu_count() / 2, 1)\n"
"        args[:] = [\"-n\", str(num)] + args"
msgstr ""

#: ../../../doc/en/example/simple.rst:108
msgid ""
"If you have the :ref:`xdist plugin <xdist>` installed you will now always "
"perform test runs using a number of subprocesses close to your CPU. Running "
"in an empty directory with the above conftest.py::"
msgstr ""

#: ../../../doc/en/example/simple.rst:113
#: ../../../doc/en/example/simple.rst:318
msgid ""
"$ py.test\n"
"======= test session starts ========\n"
"platform linux -- Python 3.5.1, pytest-2.9.2, py-1.4.31, pluggy-0.3.1\n"
"rootdir: $REGENDOC_TMPDIR, inifile:\n"
"collected 0 items\n"
"\n"
"======= no tests ran in 0.12 seconds ========"
msgstr ""

#: ../../../doc/en/example/simple.rst:124
msgid "Control skipping of tests according to command line option"
msgstr ""

#: ../../../doc/en/example/simple.rst:128
msgid ""
"Here is a ``conftest.py`` file adding a ``--runslow`` command line option to "
"control skipping of ``slow`` marked tests:"
msgstr ""

#: ../../../doc/en/example/simple.rst:131
msgid ""
"# content of conftest.py\n"
"\n"
"import pytest\n"
"def pytest_addoption(parser):\n"
"    parser.addoption(\"--runslow\", action=\"store_true\",\n"
"        help=\"run slow tests\")"
msgstr ""

#: ../../../doc/en/example/simple.rst:140
msgid "We can now write a test module like this:"
msgstr ""

#: ../../../doc/en/example/simple.rst:142
msgid ""
"# content of test_module.py\n"
"\n"
"import pytest\n"
"\n"
"\n"
"slow = pytest.mark.skipif(\n"
"    not pytest.config.getoption(\"--runslow\"),\n"
"    reason=\"need --runslow option to run\"\n"
")\n"
"\n"
"\n"
"def test_func_fast():\n"
"    pass\n"
"\n"
"\n"
"@slow\n"
"def test_func_slow():\n"
"    pass"
msgstr ""

#: ../../../doc/en/example/simple.rst:163
msgid "and when running it will see a skipped \"slow\" test::"
msgstr ""

#: ../../../doc/en/example/simple.rst:165
msgid ""
"$ py.test -rs    # \"-rs\" means report details on the little 's'\n"
"======= test session starts ========\n"
"platform linux -- Python 3.5.1, pytest-2.9.2, py-1.4.31, pluggy-0.3.1\n"
"rootdir: $REGENDOC_TMPDIR, inifile:\n"
"collected 2 items\n"
"\n"
"test_module.py .s\n"
"======= short test summary info ========\n"
"SKIP [1] test_module.py:14: need --runslow option to run\n"
"\n"
"======= 1 passed, 1 skipped in 0.12 seconds ========"
msgstr ""

#: ../../../doc/en/example/simple.rst:177
msgid "Or run it including the ``slow`` marked test::"
msgstr ""

#: ../../../doc/en/example/simple.rst:179
msgid ""
"$ py.test --runslow\n"
"======= test session starts ========\n"
"platform linux -- Python 3.5.1, pytest-2.9.2, py-1.4.31, pluggy-0.3.1\n"
"rootdir: $REGENDOC_TMPDIR, inifile:\n"
"collected 2 items\n"
"\n"
"test_module.py ..\n"
"\n"
"======= 2 passed in 0.12 seconds ========"
msgstr ""

#: ../../../doc/en/example/simple.rst:190
msgid "Writing well integrated assertion helpers"
msgstr ""

#: ../../../doc/en/example/simple.rst:194
msgid ""
"If you have a test helper function called from a test you can use the "
"``pytest.fail`` marker to fail a test with a certain message. The test "
"support function will not show up in the traceback if you set the "
"``__tracebackhide__`` option somewhere in the helper function. Example:"
msgstr ""

#: ../../../doc/en/example/simple.rst:200
msgid ""
"# content of test_checkconfig.py\n"
"import pytest\n"
"def checkconfig(x):\n"
"    __tracebackhide__ = True\n"
"    if not hasattr(x, \"config\"):\n"
"        pytest.fail(\"not configured: %s\" %(x,))\n"
"\n"
"def test_something():\n"
"    checkconfig(42)"
msgstr ""

#: ../../../doc/en/example/simple.rst:212
msgid ""
"The ``__tracebackhide__`` setting influences ``pytest`` showing of "
"tracebacks: the ``checkconfig`` function will not be shown unless the ``--"
"full-trace`` command line option is specified. Let's run our little "
"function::"
msgstr ""

#: ../../../doc/en/example/simple.rst:217
msgid ""
"$ py.test -q test_checkconfig.py\n"
"F\n"
"======= FAILURES ========\n"
"_______ test_something ________\n"
"\n"
"    def test_something():\n"
">       checkconfig(42)\n"
"E       Failed: not configured: 42\n"
"\n"
"test_checkconfig.py:8: Failed\n"
"1 failed in 0.12 seconds"
msgstr ""

#: ../../../doc/en/example/simple.rst:230
msgid "Detect if running from within a pytest run"
msgstr ""

#: ../../../doc/en/example/simple.rst:234
msgid ""
"Usually it is a bad idea to make application code behave differently if "
"called from a test.  But if you absolutely must find out if your application "
"code is running from a test you can do something like this:"
msgstr ""

#: ../../../doc/en/example/simple.rst:239
msgid ""
"# content of conftest.py\n"
"\n"
"def pytest_configure(config):\n"
"    import sys\n"
"    sys._called_from_test = True\n"
"\n"
"def pytest_unconfigure(config):\n"
"    del sys._called_from_test"
msgstr ""

#: ../../../doc/en/example/simple.rst:250
msgid "and then check for the ``sys._called_from_test`` flag:"
msgstr ""

#: ../../../doc/en/example/simple.rst:252
msgid ""
"if hasattr(sys, '_called_from_test'):\n"
"    # called from within a test run\n"
"else:\n"
"    # called \"normally\""
msgstr ""

#: ../../../doc/en/example/simple.rst:259
msgid ""
"accordingly in your application.  It's also a good idea to use your own "
"application module rather than ``sys`` for handling flag."
msgstr ""

#: ../../../doc/en/example/simple.rst:264
msgid "Adding info to test report header"
msgstr ""

#: ../../../doc/en/example/simple.rst:268
msgid "It's easy to present extra information in a ``pytest`` run:"
msgstr ""

#: ../../../doc/en/example/simple.rst:270
msgid ""
"# content of conftest.py\n"
"\n"
"def pytest_report_header(config):\n"
"    return \"project deps: mylib-1.1\""
msgstr ""

#: ../../../doc/en/example/simple.rst:277
msgid "which will add the string to the test header accordingly::"
msgstr ""

#: ../../../doc/en/example/simple.rst:279
msgid ""
"$ py.test\n"
"======= test session starts ========\n"
"platform linux -- Python 3.5.1, pytest-2.9.2, py-1.4.31, pluggy-0.3.1\n"
"project deps: mylib-1.1\n"
"rootdir: $REGENDOC_TMPDIR, inifile:\n"
"collected 0 items\n"
"\n"
"======= no tests ran in 0.12 seconds ========"
msgstr ""

#: ../../../doc/en/example/simple.rst:290
msgid ""
"You can also return a list of strings which will be considered as several "
"lines of information.  You can of course also make the amount of reporting "
"information on e.g. the value of ``config.option.verbose`` so that you "
"present more information appropriately:"
msgstr ""

#: ../../../doc/en/example/simple.rst:295
msgid ""
"# content of conftest.py\n"
"\n"
"def pytest_report_header(config):\n"
"    if config.option.verbose > 0:\n"
"        return [\"info1: did you know that ...\", \"did you?\"]"
msgstr ""

#: ../../../doc/en/example/simple.rst:303
