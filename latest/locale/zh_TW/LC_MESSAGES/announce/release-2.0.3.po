#: ../../../doc/en/announce/release-2.0.3.rst:2
msgid "py.test 2.0.3: bug fixes and speed ups"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:4
msgid ""
"Welcome to pytest-2.0.3, a maintenance and bug fix release of pytest, a "
"mature testing tool for Python, supporting CPython 2.4-3.2, Jython and "
"latest PyPy interpreters.  See the extensive docs with tested examples here:"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:8
msgid "http://pytest.org/"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:10
msgid "If you want to install or upgrade pytest, just type one of::"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:12
msgid ""
"pip install -U pytest # or\n"
"easy_install -U pytest"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:15
msgid ""
"There also is a bugfix release 1.6 of pytest-xdist, the plugin that enables "
"seamless distributed and \"looponfail\" testing for Python."
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:18
msgid "best, holger krekel"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:22
msgid "Changes between 2.0.2 and 2.0.3"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:24
msgid ""
"fix issue38: nicer tracebacks on calls to hooks, particularly early "
"configure/sessionstart ones"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:27
msgid ""
"fix missing skip reason/meta information in junitxml files, reported via "
"http://lists.idyll.org/pipermail/testing-in-python/2011-March/003928.html"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:30
msgid ""
"fix issue34: avoid collection failure with \"test\" prefixed classes "
"deriving from object."
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:33
msgid ""
"don't require zlib (and other libs) for genscript plugin without --genscript "
"actually being used."
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:36
msgid ""
"speed up skips (by not doing a full traceback representation internally)"
msgstr ""

#: ../../../doc/en/announce/release-2.0.3.rst:39
msgid "fix issue37: avoid invalid characters in junitxml's output"
msgstr ""
