#: ../../../doc/en/announce/release-2.4.1.rst:2
msgid "pytest-2.4.1: fixing three regressions compared to 2.3.5"
msgstr ""

#: ../../../doc/en/announce/release-2.4.1.rst:4
msgid ""
"pytest-2.4.1 is a quick follow up release to fix three regressions compared "
"to 2.3.5 before they hit more people:"
msgstr ""

#: ../../../doc/en/announce/release-2.4.1.rst:7
msgid ""
"When using parser.addoption() unicode arguments to the \"type\" keyword "
"should also be converted to the respective types. thanks Floris Bruynooghe, "
"@dnozay. (fixes issue360 and issue362)"
msgstr ""

#: ../../../doc/en/announce/release-2.4.1.rst:11
msgid ""
"fix dotted filename completion when using argcomplete thanks Anthon van der "
"Neuth. (fixes issue361)"
msgstr ""

#: ../../../doc/en/announce/release-2.4.1.rst:14
msgid ""
"fix regression when a 1-tuple (\"arg\",) is used for specifying "
"parametrization (the values of the parametrization were passed nested in a "
"tuple).  Thanks Donald Stufft."
msgstr ""

#: ../../../doc/en/announce/release-2.4.1.rst:18
msgid "also merge doc typo fixes, thanks Andy Dirnberger"
msgstr ""

#: ../../../doc/en/announce/release-2.4.1.rst:20
msgid "as usual, docs at http://pytest.org and upgrades via::"
msgstr ""

#: ../../../doc/en/announce/release-2.4.1.rst:22
msgid "pip install -U pytest"
msgstr "pip install -U pytest"

#: ../../../doc/en/announce/release-2.4.1.rst:24
msgid "have fun, holger krekel"
msgstr ""
