#: ../../../doc/en/reference/reference.rst:1379
msgid ""
"[pytest]\n"
"collect_imported_tests = false"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1384
msgid ""
"pytest traditionally collects classes/functions in the test module namespace "
"even if they are imported from another file."
msgstr ""

