#: ../../../doc/en/reference/reference.rst:2393
#: ../../../doc/en/reference/reference.rst:2400
msgid ""
"[pytest]\n"
"strict_config = true"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2405
#: ../../../doc/en/reference/reference.rst:2428
#: ../../../doc/en/reference/reference.rst:2454
#: ../../../doc/en/reference/reference.rst:2505
msgid "You can also enable this option via the :confval:`strict` option."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2412
msgid ""
"If set to ``true``, markers not registered in the ``markers`` section of the "
"configuration file will raise errors."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2416
#: ../../../doc/en/reference/reference.rst:2423
msgid ""
"[pytest]\n"
"strict_markers = true"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2435
msgid ""
"If set to ``true``, pytest emits an error if it detects non-unique parameter "
"set IDs."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2437
msgid ""
"If not set, pytest automatically handles this by adding `0`, `1`, ... to "
"duplicate IDs, making them unique."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2442
#: ../../../doc/en/reference/reference.rst:2449
msgid ""
"[pytest]\n"
"strict_parametrization_ids = true"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2456
msgid "For example,"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2458
msgid ""
"import pytest\n"
"\n"
"\n"
"@pytest.mark.parametrize(\"letter\", [\"a\", \"a\"])\n"
"def test_letter_is_ascii(letter):\n"
"    assert letter.isascii()"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2467
msgid ""
"will emit an error because both cases (parameter sets) have the same auto-"
"generated ID \"a\"."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2469
msgid ""
"To fix the error, if you decide to keep the duplicates, explicitly assign "
"unique IDs:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2471
msgid ""
"import pytest\n"
"\n"
"\n"
"@pytest.mark.parametrize(\"letter\", [\"a\", \"a\"], ids=[\"a0\", \"a1\"])\n"
"def test_letter_is_ascii(letter):\n"
"    assert letter.isascii()"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2480
msgid ""
"See :func:`parametrize <pytest.Metafunc.parametrize>` and :func:`pytest."
"param` for other ways to set IDs."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2487
msgid ""
"If set to ``true``, tests marked with ``@pytest.mark.xfail`` that actually "
"succeed will by default fail the test suite. For more information, see :ref:"
"`xfail strict tutorial`."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2493
#: ../../../doc/en/reference/reference.rst:2500
msgid ""
"[pytest]\n"
"strict_xfail = true"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2507
msgid ""
"Renamed from ``xfail_strict`` to ``strict_xfail``. ``xfail_strict`` is "
"accepted as an alias for ``strict_xfail``."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2515
msgid ""
"Sets list of directories that should be searched for tests when no specific "
"directories, files or test ids are given in the command line when executing "
"pytest from the :ref:`rootdir <rootdir>` directory. File system paths may "
"use shell-style wildcards, including the recursive ``**`` pattern."
