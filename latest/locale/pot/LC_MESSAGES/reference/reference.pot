msgid "Example of a test requiring a fixture:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:335
msgid ""
"def test_output(capsys):\n"
"    print(\"hello\")\n"
"    out, err = capsys.readouterr()\n"
"    assert out == \"hello\\n\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:343
msgid "Example of a fixture requiring another fixture:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:345
msgid ""
"@pytest.fixture\n"
"def db_session(tmp_path):\n"
"    fn = tmp_path / \"db.file\"\n"
"    return connect(fn)"
msgstr ""

