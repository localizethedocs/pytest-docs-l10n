"at least one warning of that class or classes."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.warns:7
msgid ""
"This helper produces a list of :class:`warnings.WarningMessage` objects, one "
"for each warning emitted (regardless of whether it is an "
"``expected_warning`` or not). Since pytest 8.0, unmatched warnings are also "
"re-emitted when the context closes."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.warns:11
msgid "This function should be used as a context manager::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.warns:13
msgid ""
">>> import pytest\n"
">>> with pytest.warns(RuntimeWarning):\n"
"...    warnings.warn(\"my warning\", RuntimeWarning)"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.warns:17
msgid ""
"The ``match`` keyword argument can be used to assert that the warning "
"matches a text or regex::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.warns:20
msgid ""
">>> with pytest.warns(UserWarning, match='must be 0 or None'):\n"
"...     warnings.warn(\"value must be 0 or None\", UserWarning)\n"
"\n"
">>> with pytest.warns(UserWarning, match=r'must be \\d+$'):\n"
"...     warnings.warn(\"value must be 42\", UserWarning)\n"
"\n"
">>> with pytest.warns(UserWarning):  # catch re-emitted warning\n"
"...     with pytest.warns(UserWarning, match=r'must be \\d+$'):\n"
"...         warnings.warn(\"this is not here\", UserWarning)\n"
"Traceback (most recent call last):\n"
"  ...\n"
"Failed: Regex pattern did not match any of the 1 warnings emitted.\n"
" Regex: ...\n"
" Emitted warnings: ...UserWarning..."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.warns:37
msgid ""
"When using :ref:`pytest.mark.parametrize ref` it is possible to parametrize "
"tests such that some runs raise a warning and others do not."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
