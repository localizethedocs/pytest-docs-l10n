#: ../../../doc/en/reference/reference.rst:2559
msgid ""
"[pytest]\n"
"tmp_path_retention_count = \"3\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:2566
msgid ""
"[pytest]\n"
"tmp_path_retention_count = 3"
