msgid ""
"[pytest]\n"
"testpaths = [\"testing\", \"doc\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2533
msgid ""
"[pytest]\n"
"testpaths = testing doc"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2538
msgid "This configuration means that executing:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2540
msgid "pytest"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2544
