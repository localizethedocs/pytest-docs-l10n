msgid "``xfail`` marks tests with an empty parameterset as xfail(run=False)"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1510
msgid ""
"``fail_at_collect`` raises an exception if parametrize collects an empty "
"parameter set"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1514
msgid ""
"[pytest]\n"
"empty_parameter_set_mark = \"xfail\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1521
msgid ""
"[pytest]\n"
"empty_parameter_set_mark = xfail"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1528
msgid ""
"The default value of this option is planned to change to ``xfail`` in future "
"releases as this is considered less error prone, see :issue:`3155` for more "
"details."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1536
msgid ""
"Enables the :hook:`pytest_assertion_pass` hook. Make sure to delete any "
"previously generated ``.pyc`` cache files."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1558
msgid ""
"Exit the pytest process after the per-test timeout is reached by passing "
"`exit=True` to the :func:`faulthandler.dump_traceback_later` function. This "
"is particularly useful to avoid wasting CI resources for test suites that "
"are prone to putting the main Python interpreter into a deadlock state."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1565
#: ../../../doc/en/reference/reference.rst:1573
msgid ""
"[pytest]\n"
"faulthandler_timeout = 5\n"
"faulthandler_exit_on_timeout = true"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1585
msgid ""
"Dumps the tracebacks of all threads if a test takes longer than ``X`` "
"seconds to run (including fixture setup and teardown). Implemented using "
"the :func:`faulthandler.dump_traceback_later` function, so all caveats there "
"apply."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1591
#: ../../../doc/en/reference/reference.rst:1598
msgid ""
"[pytest]\n"
"faulthandler_timeout = 5"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1603
msgid "For more information please refer to :ref:`faulthandler`."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1609
msgid ""
"Sets a list of filters and actions that should be taken for matched "
"warnings. By default all warnings emitted during the test session will be "
"displayed in a summary at the end of the test session."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1615
msgid ""
"[pytest]\n"
"filterwarnings = [\n"
"    'error',\n"
"    'ignore::DeprecationWarning',\n"
"    # Note the use of single quote below to denote \"raw\" strings in TOML.\n"
"    'ignore:function ham\\(\\) should not be used:UserWarning',\n"
"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1627
msgid ""
"[pytest]\n"
"filterwarnings =\n"
"    error\n"
"    ignore::DeprecationWarning\n"
"    ignore:function ham\\(\\) should not be used:UserWarning"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1635
msgid ""
"This tells pytest to ignore deprecation warnings and turn all other warnings "
"into errors. For more information please refer to :ref:`warnings`."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1644
msgid ""
"Maximum number of warnings allowed before the test run is considered a "
"failure. When all tests pass, but the total number of warnings exceeds this "
"value, pytest exits with :class:`pytest.ExitCode` ``MAX_WARNINGS_ERROR`` "
"(code ``6``)."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1650
#: ../../../doc/en/reference/reference.rst:1657
msgid ""
"[pytest]\n"
"max_warnings = 10"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1662
msgid ""
"Note that :confval:`filtered warnings <filterwarnings>` do not count toward "
"this maximum total."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1664
msgid "Can also be set via the :option:`--max-warnings` command-line option."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1673
msgid "Configures how durations are recorded into the JUnit XML report:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1675
msgid ""
"``total``: duration times reported include setup, call, and teardown times."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1676
msgid ""
"``call``: duration times reported include only call times, excluding setup "
"and teardown."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1680
msgid ""
"[pytest]\n"
"junit_duration_report = \"call\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1687
msgid ""
"[pytest]\n"
"junit_duration_report = call"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1698
msgid "Default changed to ``xunit2``."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1701
msgid ""
"Configures the format of the generated JUnit XML file. The possible options "
"are:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1703
msgid ""
"``xunit1`` (or ``legacy``): produces old style output, compatible with the "
"xunit 1.0 format."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1704
msgid ""
"``xunit2``: produces `xunit 2.0 style output <https://github.com/jenkinsci/"
"xunit-plugin/blob/xunit-2.3.2/src/main/resources/org/jenkinsci/plugins/xunit/"
"types/model/xsd/junit-10.xsd>`__, which should be more compatible with "
"latest Jenkins versions."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1708
msgid ""
"[pytest]\n"
"junit_family = \"xunit2\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1715
msgid ""
"[pytest]\n"
"junit_family = xunit2"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1727
msgid ""
"If ``junit_logging != \"no\"``, configures if the captured output should be "
"written to the JUnit XML file for **passing** tests."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1732
msgid ""
"[pytest]\n"
"junit_log_passing_tests = false"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1739
msgid ""
"[pytest]\n"
"junit_log_passing_tests = False"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1750
msgid "``log``, ``all``, ``out-err`` options added."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1753
msgid ""
"Configures if captured output should be written to the JUnit XML file. Valid "
"values are:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1755
msgid "``log``: write only ``logging`` captured output."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1756
msgid "``system-out``: write captured ``stdout`` contents."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1757
msgid "``system-err``: write captured ``stderr`` contents."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1758
msgid "``out-err``: write both captured ``stdout`` and ``stderr`` contents."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1759
msgid ""
"``all``: write captured ``logging``, ``stdout`` and ``stderr`` contents."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1760
msgid "``no``: no captured output is written."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1764
msgid ""
"[pytest]\n"
"junit_logging = \"system-out\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1771
msgid ""
"[pytest]\n"
"junit_logging = system-out"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1781
msgid ""
"To set the name of the root test suite xml item, you can configure the "
"``junit_suite_name`` option in your config file:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1785
msgid ""
"[pytest]\n"
"junit_suite_name = \"my_suite\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1792
msgid ""
"[pytest]\n"
"junit_suite_name = my_suite"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1801
msgid "Allow selective auto-indentation of multiline log messages."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1803
msgid ""
"Supports command line option :option:`--log-auto-indent=[value]` and config "
"option ``log_auto_indent = [value]`` to set the auto-indentation behavior "
"for all logging."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1807
msgid "``[value]`` can be:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1808
msgid "\"True\" or \"On\" - Dynamically auto-indent multiline log messages"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1809
msgid ""
"\"False\" or \"Off\" or \"0\" - Do not auto-indent multiline log messages"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1810
msgid ""
"\"[positive integer]\" - auto-indent multiline log messages by [value] spaces"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1814
msgid ""
"[pytest]\n"
"log_auto_indent = \"false\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1821
msgid ""
"[pytest]\n"
"log_auto_indent = false"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1826
msgid ""
"Supports passing kwarg ``extra={\"auto_indent\": [value]}`` to calls to "
"``logging.log()`` to specify auto-indentation behavior for a specific entry "
"in the log. ``extra`` kwarg overrides the value specified on the command "
"line or in the config."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1835
msgid ""
"Enable log display during test run (also known as :ref:`\"live logging\" "
"<live_logs>`)."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1839
#: ../../../doc/en/reference/reference.rst:1846
msgid ""
"[pytest]\n"
"log_cli = true"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1855
msgid ""
"Sets a :py:func:`time.strftime`-compatible string that will be used when "
"formatting dates for live logging."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1859
msgid ""
"[pytest]\n"
"log_cli_date_format = \"%Y-%m-%d %H:%M:%S\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1866
msgid ""
"[pytest]\n"
"log_cli_date_format = %Y-%m-%d %H:%M:%S"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1871
#: ../../../doc/en/reference/reference.rst:1893
#: ../../../doc/en/reference/reference.rst:1920
msgid "For more information, see :ref:`live_logs`."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1877
msgid ""
"Sets a :py:mod:`logging`-compatible string used to format live logging "
"messages."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1881
msgid ""
"[pytest]\n"
"log_cli_format = \"%(asctime)s %(levelname)s %(message)s\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1888
msgid ""
"[pytest]\n"
"log_cli_format = %(asctime)s %(levelname)s %(message)s"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1900
msgid ""
"Sets the minimum log message level that should be captured for live logging. "
"The integer value or the names of the levels can be used. Note in TOML the "
"integer must be quoted, as there is no support for config parameters of "
"mixed type."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1906
msgid ""
"[pytest]\n"
"log_cli_level = \"INFO\"\n"
"log_cli_level = \"10\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1914
msgid ""
"[pytest]\n"
"log_cli_level = INFO\n"
"log_cli_level = 10"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1927
msgid ""
"Sets a :py:func:`time.strftime`-compatible string that will be used when "
"formatting dates for logging capture."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1931
msgid ""
"[pytest]\n"
"log_date_format = \"%Y-%m-%d %H:%M:%S\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1938
msgid ""
"[pytest]\n"
"log_date_format = %Y-%m-%d %H:%M:%S"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1943
#: ../../../doc/en/reference/reference.rst:1966
#: ../../../doc/en/reference/reference.rst:1989
#: ../../../doc/en/reference/reference.rst:2011
#: ../../../doc/en/reference/reference.rst:2036
#: ../../../doc/en/reference/reference.rst:2060
#: ../../../doc/en/reference/reference.rst:2083
#: ../../../doc/en/reference/reference.rst:2110
msgid "For more information, see :ref:`logging`."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1949
msgid ""
"Sets a file name relative to the current working directory where log "
"messages should be written to, in addition to the other logging facilities "
"that are active."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1954
msgid ""
"[pytest]\n"
"log_file = \"logs/pytest-logs.txt\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1961
msgid ""
"[pytest]\n"
"log_file = logs/pytest-logs.txt"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1973
msgid ""
"Sets a :py:func:`time.strftime`-compatible string that will be used when "
"formatting dates for the logging file."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1977
msgid ""
"[pytest]\n"
"log_file_date_format = \"%Y-%m-%d %H:%M:%S\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1984
msgid ""
"[pytest]\n"
"log_file_date_format = %Y-%m-%d %H:%M:%S"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1995
msgid ""
"Sets a :py:mod:`logging`-compatible string used to format logging messages "
"redirected to the logging file."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1999
msgid ""
"[pytest]\n"
"log_file_format = \"%(asctime)s %(levelname)s %(message)s\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:2006
msgid ""
"[pytest]\n"
"log_file_format = %(asctime)s %(levelname)s %(message)s"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2017
msgid ""
"Sets the minimum log message level that should be captured for the logging "
"file. The integer value (in TOML, as a string) or the names of the levels "
"can be used."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2022
msgid ""
"[pytest]\n"
"log_file_level = \"INFO\"\n"
"log_cli_level = \"10\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:2030
msgid ""
"[pytest]\n"
"log_file_level = INFO\n"
"log_cli_level = 10"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2043
msgid ""
"Sets the mode that the logging file is opened with. The options are "
"``\"w\"`` to recreate the file or ``\"a\"`` to append to the file."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2048
msgid ""
"[pytest]\n"
"log_file_mode = \"a\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:2055
msgid ""
"[pytest]\n"
"log_file_mode = a"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2067
msgid ""
"Sets a :py:mod:`logging`-compatible string used to format captured logging "
"messages."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2071
msgid ""
"[pytest]\n"
"log_format = \"%(asctime)s %(levelname)s %(message)s\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:2078
msgid ""
"[pytest]\n"
"log_format = %(asctime)s %(levelname)s %(message)s"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2089
msgid ""
"Sets the minimum log message level that should be captured for logging "
"capture. Not set by default, so it depends on the root/parent log handler's "
"effective level, where it is ``\"WARNING\"`` by default. The integer value "
"(in TOML, as a string) or the names of the levels can be used."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2096
msgid ""
"[pytest]\n"
"log_level = \"INFO\"\n"
"log_cli_level = \"10\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:2104
msgid ""
"[pytest]\n"
"log_level = INFO\n"
"log_cli_level = 10"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2116
msgid ""
"When the :confval:`strict_markers` configuration option is set, only known "
"markers - defined in code by core pytest or some plugin - are allowed."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2119
msgid ""
"You can list additional markers in this setting to add them to the "
"whitelist, in which case you probably want to set :confval:`strict_markers` "
"to ``true`` to avoid future regressions:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2125
msgid ""
"[pytest]\n"
"addopts = [\"--strict-markers\"]\n"
"markers = [\"slow\", \"serial\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2133
msgid ""
"[pytest]\n"
"strict_markers = true\n"
"markers =\n"
"    slow\n"
"    serial"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2145
msgid "Specifies a minimal pytest version required for running tests."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2149
#: ../../../doc/en/reference/reference.rst:2156
msgid ""
"[pytest]\n"
"minversion = 3.0  # will fail if we run with pytest-2.8"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2166
msgid ""
"Set the directory basename patterns to avoid when recursing for test "
"discovery.  The individual (fnmatch-style) patterns are applied to the "
"basename of a directory to decide if to recurse into it. Pattern matching "
"characters::"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2171
msgid ""
"*       matches everything\n"
"?       matches any single character\n"
"[seq]   matches any character in seq\n"
"[!seq]  matches any char not in seq"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2176
msgid ""
"Setting a ``norecursedirs`` replaces the default.  Here is an example of how "
"to avoid certain directories:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2181
msgid ""
"[pytest]\n"
"norecursedirs = [\".svn\", \"_build\", \"tmp*\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2188
msgid ""
"[pytest]\n"
"norecursedirs = .svn _build tmp*"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2193
msgid ""
"This would tell ``pytest`` to not look into typical subversion or sphinx-"
"build directories or into any ``tmp`` prefixed directory."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2196
msgid ""
"Additionally, ``pytest`` will attempt to intelligently identify and ignore a "
"virtualenv.  Any directory deemed to be the root of a virtual environment "
"will not be considered during test collection unless :option:`--collect-in-"
"virtualenv` is given.  Note also that ``norecursedirs`` takes precedence "
"over ``--collect-in-virtualenv``; e.g. if you intend to run tests in a "
"virtualenv with a base directory that matches ``'.*'`` you *must* override "
"``norecursedirs`` in addition to using the ``--collect-in-virtualenv`` flag."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2210
msgid ""
"One or more name prefixes or glob-style patterns determining which classes "
"are considered for test collection. Search for multiple glob patterns by "
"adding a space between patterns. By default, pytest will consider any class "
"prefixed with ``Test`` as a test collection.  Here is an example of how to "
"collect tests from classes that end in ``Suite``:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2218
msgid ""
"[pytest]\n"
"python_classes = [\"*Suite\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2225
msgid ""
"[pytest]\n"
"python_classes = *Suite"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2230
msgid ""
"Note that ``unittest.TestCase`` derived classes are always collected "
"regardless of this option, as ``unittest``'s own collection framework is "
"used to collect those tests."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2239
msgid ""
"One or more Glob-style file patterns determining which python files are "
"considered as test modules. Search for multiple glob patterns by adding a "
"space between patterns:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2245
msgid ""
"[pytest]\n"
"python_files = [\"test_*.py\", \"check_*.py\", \"example_*.py\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2252
msgid ""
"[pytest]\n"
"python_files = test_*.py check_*.py example_*.py"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2257
msgid "Or one per line:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2259
msgid ""
"[pytest]\n"
"python_files =\n"
"    test_*.py\n"
"    check_*.py\n"
"    example_*.py"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2273
msgid ""
"One or more name prefixes or glob-patterns determining which test functions "
"and methods are considered tests. Search for multiple glob patterns by "
"adding a space between patterns. By default, pytest will consider any "
"function prefixed with ``test`` as a test.  Here is an example of how to "
"collect test functions and methods that end in ``_test``:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2281
msgid ""
"[pytest]\n"
"python_functions = [\"*_test\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2288
msgid ""
"[pytest]\n"
"python_functions = *_test"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2293
msgid ""
"Note that this has no effect on methods that live on a ``unittest.TestCase`` "
"derived class, as ``unittest``'s own collection framework is used to collect "
"those tests."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2297
msgid "See :ref:`change naming conventions` for more detailed examples."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2303
msgid ""
"Sets list of directories that should be added to the python search path. "
"Directories will be added to the head of :data:`sys.path`. Similar to the :"
"envvar:`PYTHONPATH` environment variable, the directories will be included "
"in where Python will look for imported modules. Paths are relative to the :"
"ref:`rootdir <rootdir>` directory. Directories remain in path for the "
"duration of the test session."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2312
msgid ""
"[pytest]\n"
"pythonpath = [\"src1\", \"src2\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2319
msgid ""
"[pytest]\n"
"pythonpath = src1 src2"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2328
msgid ""
"A space separated list of plugins that must be present for pytest to run. "
"Plugins can be listed with or without version specifiers directly following "
"their name. Whitespace between different version specifiers is not allowed. "
"If any one of the plugins is not found, emit an error."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2335
msgid ""
"[pytest]\n"
"required_plugins = [\"pytest-django>=3.0.0,<4.0.0\", \"pytest-html\", "
"\"pytest-xdist>=1.0.0\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2342
msgid ""
"[pytest]\n"
"required_plugins = pytest-django>=3.0.0,<4.0.0 pytest-html pytest-"
"xdist>=1.0.0"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2352
msgid ""
"If set to ``true``, enable \"strict mode\", which enables the following "
"options:"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2354
msgid ":confval:`strict_config`"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2355
msgid ":confval:`strict_markers`"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2356
msgid ":confval:`strict_parametrization_ids`"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2357
msgid ":confval:`strict_xfail`"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2359
msgid "Plugins may also enable their own strictness options."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2361
msgid ""
"If you explicitly set an individual strictness option, it takes precedence "
"over ``strict``."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2364
msgid ""
"If pytest adds new strictness options in the future, they will also be "
"enabled in strict mode. Therefore, you should only enable strict mode if you "
"use a pinned/locked version of pytest, or if you want to proactively adopt "
"new strictness options as they are added."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2370
