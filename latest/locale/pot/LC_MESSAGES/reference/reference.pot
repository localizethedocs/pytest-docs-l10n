#: ../../../doc/en/reference/reference.rst:2592
msgid ""
"[pytest]\n"
"tmp_path_retention_policy = all"
msgstr ""

#: ../../../doc/en/reference/reference.rst:2602
msgid ""
"Controls maximum number of characters to truncate assertion message contents."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2604
msgid "Setting value to ``0`` disables the character limit for truncation."
msgstr ""

#: ../../../doc/en/reference/reference.rst:2608
#: ../../../doc/en/reference/reference.rst:2615
msgid ""
"[pytest]\n"
"truncation_limit_chars = 640"
