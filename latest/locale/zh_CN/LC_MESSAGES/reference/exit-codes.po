msgid "Exit codes"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:6
msgid "Running ``pytest`` can result in six different exit codes:"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:0
msgid "Exit code 0"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:8
msgid "All tests were collected and passed successfully"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:0
msgid "Exit code 1"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:9
msgid "Tests were collected and run but some of the tests failed"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:0
msgid "Exit code 2"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:10
msgid "Test execution was interrupted by the user"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:0
msgid "Exit code 3"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:11
msgid "Internal error happened while executing tests"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:0
msgid "Exit code 4"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:12
msgid "pytest command line usage error"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:0
msgid "Exit code 5"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:13
msgid "No tests were collected"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:15
msgid ""
"They are represented by the :class:`pytest.ExitCode` enum. The exit codes "
"being a part of the public API can be imported and accessed directly using:"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:17
msgid "from pytest import ExitCode"
msgstr ""

#: ../../../doc/en/reference/exit-codes.rst:23
msgid ""
"If you would like to customize the exit code in some scenarios, specifically "
"when no tests are collected, consider using the `pytest-custom_exit_code "
"<https://github.com/yashtodi94/pytest-custom_exit_code>`__ plugin."
msgstr ""
