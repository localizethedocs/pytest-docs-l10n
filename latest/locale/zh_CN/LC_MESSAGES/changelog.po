#: ../../../doc/en/changelog.rst:7367
msgid "Pin ``pluggy`` to ``<0.8``. (:issue:`3727`)"
msgstr ""

#: ../../../doc/en/changelog.rst:7371
msgid "pytest 3.6.3 (2018-07-04)"
msgstr ""

#: ../../../doc/en/changelog.rst:7376
msgid ""
"Fix ``ImportWarning`` triggered by explicit relative imports in assertion-"
