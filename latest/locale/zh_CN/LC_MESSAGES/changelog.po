msgid "Deprecations"
msgstr ""

#: ../../../doc/en/changelog.rst:1449
msgid ""
"`#12069 <https://github.com/pytest-dev/pytest/issues/12069>`_: A deprecation "
"warning is now raised when implementations of one of the following hooks "
"request a deprecated ``py.path.local`` parameter instead of the ``pathlib."
"Path`` parameter which replaced it:"
msgstr ""

#: ../../../doc/en/changelog.rst:1451
msgid ""
":hook:`pytest_ignore_collect` - the ``path`` parameter - use "
"``collection_path`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:1452
msgid ""
":hook:`pytest_collect_file` - the ``path`` parameter - use ``file_path`` "
"instead."
msgstr ""

#: ../../../doc/en/changelog.rst:1453
msgid ""
":hook:`pytest_pycollect_makemodule` - the ``path`` parameter - use "
"``module_path`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:1454
msgid ""
":hook:`pytest_report_header` - the ``startdir`` parameter - use "
"``start_path`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:1455
msgid ""
":hook:`pytest_report_collectionfinish` - the ``startdir`` parameter - use "
"``start_path`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:1457
msgid ""
"The replacement parameters are available since pytest 7.0.0. The old "
"parameters will be removed in pytest 9.0.0."
msgstr ""

#: ../../../doc/en/changelog.rst:1460
msgid "See :ref:`legacy-path-hooks-deprecated` for more details."
msgstr ""

