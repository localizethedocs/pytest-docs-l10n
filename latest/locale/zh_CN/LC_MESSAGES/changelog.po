msgstr ""

#: ../../../doc/en/changelog.rst:4623
msgid "pytest 5.3.3 (2020-01-16)"
msgstr ""

#: ../../../doc/en/changelog.rst:4628
msgid ":issue:`2780`: Captured output during teardown is shown with ``-rP``."
msgstr ""

