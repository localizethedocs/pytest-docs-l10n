msgstr ""

#: ../../../doc/en/changelog.rst:4647
msgid ":issue:`6350`: Optimized automatic renaming of test parameter IDs."
msgstr ""

#: ../../../doc/en/changelog.rst:4651
msgid "pytest 5.3.2 (2019-12-13)"
msgstr ""

#: ../../../doc/en/changelog.rst:4666 ../../../doc/en/changelog.rst:5503
msgid ""
":issue:`5430`: junitxml: Logs for failed test are now passed to junit report "
