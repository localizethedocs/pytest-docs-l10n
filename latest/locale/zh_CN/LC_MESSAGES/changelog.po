msgstr ""

#: ../../../doc/en/changelog.rst:7326
msgid ":issue:`980`: Fix truncated locals output in verbose mode."
msgstr ""

#: ../../../doc/en/changelog.rst:7333
msgid ""
":issue:`3295`: Correct the usage documentation of ``--last-failed-no-"
