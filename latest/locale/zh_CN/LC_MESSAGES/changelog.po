msgstr ""

#: ../../../doc/en/changelog.rst:4575
msgid ""
":issue:`6752`: When :py:func:`pytest.raises` is used as a function (as "
"opposed to a context manager), a `match` keyword argument is now passed "
"through to the tested function. Previously it was swallowed and ignored "
"(regression in pytest 5.1.0)."
msgstr ""

#: ../../../doc/en/changelog.rst:4580
msgid ""
":issue:`6801`: Do not display empty lines in between traceback for "
"unexpected exceptions with doctests."
msgstr ""

#: ../../../doc/en/changelog.rst:4583
msgid ""
":issue:`6802`: The :fixture:`testdir fixture <testdir>` works within "
"doctests now."
msgstr ""

#: ../../../doc/en/changelog.rst:4590
msgid ":issue:`6696`: Add list of fixtures to start of fixture chapter."
msgstr ""

#: ../../../doc/en/changelog.rst:4593
msgid ":issue:`6742`: Expand first sentence on fixtures into a paragraph."
msgstr ""

#: ../../../doc/en/changelog.rst:4600 ../../../doc/en/changelog.rst:5478
msgid ""
":issue:`6404`: Remove usage of ``parser`` module, deprecated in Python 3.9."
msgstr ""

#: ../../../doc/en/changelog.rst:4604
msgid "pytest 5.3.5 (2020-01-29)"
msgstr ""

#: ../../../doc/en/changelog.rst:4609
msgid ""
":issue:`6517`: Fix regression in pytest 5.3.4 causing an INTERNALERROR due "
"to a wrong assertion."
msgstr ""

#: ../../../doc/en/changelog.rst:4613
msgid "pytest 5.3.4 (2020-01-20)"
msgstr ""

#: ../../../doc/en/changelog.rst:4618
msgid ""
":issue:`6496`: Revert :issue:`6436`: unfortunately this change has caused a "
