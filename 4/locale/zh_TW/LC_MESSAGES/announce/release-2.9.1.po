#: ../../../doc/en/announce/release-2.9.1.rst:37
msgid "**Bug Fixes**"
msgstr ""

#: ../../../doc/en/announce/release-2.9.1.rst:39
msgid ""
"Improve error message when a plugin fails to load. Thanks `@nicoddemus`_ for "
"the PR."
msgstr ""

#: ../../../doc/en/announce/release-2.9.1.rst:42
msgid ""
"Fix (`#1178 <https://github.com/pytest-dev/pytest/issues/1178>`_): ``pytest."
"fail`` with non-ascii characters raises an internal pytest error. Thanks "
"`@nicoddemus`_ for the PR."
msgstr ""

#: ../../../doc/en/announce/release-2.9.1.rst:46
msgid ""
"Fix (`#469`_): junit parses report.nodeid incorrectly, when params IDs "
"contain ``::``. Thanks `@tomviner`_ for the PR (`#1431`_)."
msgstr ""

#: ../../../doc/en/announce/release-2.9.1.rst:49
msgid ""
"Fix (`#578 <https://github.com/pytest-dev/pytest/issues/578>`_): "
"SyntaxErrors containing non-ascii lines at the point of failure generated an "
"internal py.test error. Thanks `@asottile`_ for the report and "
"`@nicoddemus`_ for the PR."
msgstr ""

#: ../../../doc/en/announce/release-2.9.1.rst:54
msgid ""
"Fix (`#1437`_): When passing in a bytestring regex pattern to parameterize "
"attempt to decode it as utf-8 ignoring errors."
msgstr ""

#: ../../../doc/en/announce/release-2.9.1.rst:57
msgid ""
"Fix (`#649`_): parametrized test nodes cannot be specified to run on the "
"command line."
msgstr ""
