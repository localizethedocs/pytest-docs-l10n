#: ../../../doc/en/example/markers.rst:269
msgid "Marking whole classes or modules"
msgstr ""

#: ../../../doc/en/example/markers.rst:271
msgid ""
"You may use ``pytest.mark`` decorators with classes to apply markers to all "
"of its test methods:"
msgstr ""

#: ../../../doc/en/example/markers.rst:274
msgid ""
"# content of test_mark_classlevel.py\n"
"import pytest\n"
"\n"
"\n"
"@pytest.mark.webtest\n"
"class TestClass(object):\n"
"    def test_startup(self):\n"
"        pass\n"
"\n"
"    def test_startup_and_more(self):\n"
"        pass"
msgstr ""

#: ../../../doc/en/example/markers.rst:288
msgid ""
"This is equivalent to directly applying the decorator to the two test "
"functions."
msgstr ""

#: ../../../doc/en/example/markers.rst:291
msgid ""
"To remain backward-compatible with Python 2.4 you can also set a "
"``pytestmark`` attribute on a TestClass like this:"
msgstr ""

#: ../../../doc/en/example/markers.rst:294
msgid ""
"import pytest\n"
"\n"
"\n"
"class TestClass(object):\n"
"    pytestmark = pytest.mark.webtest"
msgstr ""

#: ../../../doc/en/example/markers.rst:302
msgid "or if you need to use multiple markers you can use a list:"
msgstr ""

#: ../../../doc/en/example/markers.rst:304
msgid ""
"import pytest\n"
"\n"
"\n"
"class TestClass(object):\n"
"    pytestmark = [pytest.mark.webtest, pytest.mark.slowtest]"
msgstr ""

#: ../../../doc/en/example/markers.rst:312
msgid "You can also set a module level marker::"
msgstr ""

#: ../../../doc/en/example/markers.rst:314
msgid ""
"import pytest\n"
"pytestmark = pytest.mark.webtest"
msgstr ""

#: ../../../doc/en/example/markers.rst:317
msgid "or multiple markers::"
msgstr ""

#: ../../../doc/en/example/markers.rst:319
msgid "pytestmark = [pytest.mark.webtest, pytest.mark.slowtest]"
msgstr ""

#: ../../../doc/en/example/markers.rst:321
msgid ""
"in which case markers will be applied (in left-to-right order) to all "
"functions and methods defined in the module."
msgstr ""

#: ../../../doc/en/example/markers.rst:327
msgid "Marking individual tests when using parametrize"
msgstr ""

#: ../../../doc/en/example/markers.rst:329
msgid ""
"When using parametrize, applying a mark will make it apply to each "
"individual test. However it is also possible to apply a marker to an "
"individual test instance:"
msgstr ""

#: ../../../doc/en/example/markers.rst:333
msgid ""
"import pytest\n"
"\n"
"\n"
"@pytest.mark.foo\n"
"@pytest.mark.parametrize(\n"
"    (\"n\", \"expected\"), [(1, 2), pytest.param((1, 3), marks=pytest.mark."
"bar), (2, 3)]\n"
")\n"
"def test_increment(n, expected):\n"
"    assert n + 1 == expected"
msgstr ""

#: ../../../doc/en/example/markers.rst:345
msgid ""
"In this example the mark \"foo\" will apply to each of the three tests, "
"whereas the \"bar\" mark is only applied to the second test. Skip and xfail "
"marks can also be applied in this way, see :ref:`skip/xfail with "
"parametrize`."
msgstr ""

#: ../../../doc/en/example/markers.rst:352
msgid "Custom marker and command line option to control test runs"
msgstr ""

#: ../../../doc/en/example/markers.rst:356
msgid ""
"Plugins can provide custom markers and implement specific behaviour based on "
"it. This is a self-contained example which adds a command line option and a "
"parametrized test function marker to run tests specifies via named "
"environments:"
msgstr ""

#: ../../../doc/en/example/markers.rst:361
msgid ""
"# content of conftest.py\n"
"\n"
"import pytest\n"
"\n"
"\n"
"def pytest_addoption(parser):\n"
"    parser.addoption(\n"
"        \"-E\",\n"
"        action=\"store\",\n"
"        metavar=\"NAME\",\n"
"        help=\"only run tests matching the environment NAME.\",\n"
"    )\n"
"\n"
"\n"
"def pytest_configure(config):\n"
"    # register an additional marker\n"
"    config.addinivalue_line(\n"
"        \"markers\", \"env(name): mark test to run only on named "
"environment\"\n"
"    )\n"
"\n"
"\n"
"def pytest_runtest_setup(item):\n"
"    envnames = [mark.args[0] for mark in item.iter_markers(name=\"env\")]\n"
"    if envnames:\n"
"        if item.config.getoption(\"-E\") not in envnames:\n"
"            pytest.skip(\"test requires env in %r\" % envnames)"
msgstr ""

#: ../../../doc/en/example/markers.rst:390
msgid "A test file using this local plugin:"
msgstr ""

#: ../../../doc/en/example/markers.rst:392
msgid ""
"# content of test_someenv.py\n"
"\n"
"import pytest\n"
"\n"
"\n"
"@pytest.mark.env(\"stage1\")\n"
"def test_basic_db_operation():\n"
"    pass"
msgstr ""

