#: ../../../doc/en/how-to/output.rst:189 ../../../doc/en/how-to/output.rst:259
msgid "Notice now that:"
msgstr ""

#: ../../../doc/en/how-to/output.rst:191 ../../../doc/en/how-to/output.rst:261
msgid "Each test inside the file gets its own line in the output."
msgstr ""

#: ../../../doc/en/how-to/output.rst:192
msgid ""
"``test_words_fail`` now shows the two failing lists in full, in addition to "
"which index differs."
msgstr ""

#: ../../../doc/en/how-to/output.rst:193
msgid ""
"``test_numbers_fail`` now shows a text diff of the two dictionaries, "
"truncated."
msgstr ""

#: ../../../doc/en/how-to/output.rst:194
msgid ""
"``test_long_text_fail`` no longer truncates the right hand side of the "
"``in`` statement, because the internal threshold for truncation is larger "
"now (2400 characters currently)."
msgstr ""

