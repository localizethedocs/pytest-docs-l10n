msgid ""
":meth:`monkeypatch.delenv(name, raising=True) <pytest.MonkeyPatch.delenv>`"
msgstr ""
":meth:`monkeypatch.delenv(name, raising=True) <pytest.MonkeyPatch.delenv>`"

#: ../../../doc/en/how-to/monkeypatch.rst:23
msgid ""
