#: ../../../doc/en/index.rst:26
msgid "A quick example"
msgstr ""

#: ../../../doc/en/index.rst:28
msgid ""
"# content of test_sample.py\n"
"def inc(x):\n"
"    return x + 1\n"
"\n"
"\n"
"def test_answer():\n"
"    assert inc(3) == 5"
msgstr ""

#: ../../../doc/en/index.rst:39
msgid "To execute it:"
msgstr ""

#: ../../../doc/en/index.rst:41
msgid ""
"$ pytest\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-7.x.y, pluggy-1.x.y\n"
"rootdir: /home/sweet/project\n"
"collected 1 item\n"
"\n"
"test_sample.py F                                                     [100%]\n"
"\n"
"================================= FAILURES "
"=================================\n"
"_______________________________ test_answer "
"________________________________\n"
"\n"
"    def test_answer():\n"
">       assert inc(3) == 5\n"
"E       assert 4 == 5\n"
"E        +  where 4 = inc(3)\n"
"\n"
"test_sample.py:6: AssertionError\n"
"========================= short test summary info "
"==========================\n"
"FAILED test_sample.py::test_answer - assert 4 == 5\n"
"============================ 1 failed in 0.12s ============================="
msgstr ""

#: ../../../doc/en/index.rst:64
msgid ""
