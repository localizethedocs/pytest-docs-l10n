#: ../../../doc/en/reference/reference.rst:1021
msgid "**Tutorial**: :ref:`customizing-test-collection`"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1011
msgid ""
"Can be declared in *conftest.py files* to exclude test directories or "
"modules. Needs to be a list of paths (``str``, :class:`pathlib.Path` or any :"
"class:`os.PathLike`)."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1014
msgid "collect_ignore = [\"setup.py\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1023
msgid ""
"Can be declared in *conftest.py files* to exclude test directories or "
"modules with Unix shell-style wildcards. Needs to be ``list[str]`` where "
"``str`` can contain glob patterns."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1027
msgid "collect_ignore_glob = [\"*_ignore.py\"]"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1034
msgid "**Tutorial**: :ref:`available installable plugins`"
msgstr ""

#: ../../../doc/en/reference/reference.rst:1036
msgid ""
"Can be declared at the **global** level in *test modules* and *conftest.py "
"files* to register additional plugins. Can be either a ``str`` or "
"``Sequence[str]``."
msgstr ""

#: ../../../doc/en/reference/reference.rst:1039
msgid "pytest_plugins = \"myapp.testsupport.myplugin\""
msgstr ""

#: ../../../doc/en/reference/reference.rst:1043
msgid ""
