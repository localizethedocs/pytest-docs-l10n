#: of _pytest.mark.structures.MarkDecorator:5
msgid ""
"mark1 = pytest.mark.NAME              # Simple MarkDecorator\n"
"mark2 = pytest.mark.NAME(name1=value) # Parametrized MarkDecorator"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:8
msgid "and can then be applied as decorators to test functions::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:10
msgid ""
"@mark2\n"
"def test_function():\n"
"    pass"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:14
msgid "When a ``MarkDecorator`` is called, it does the following:"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:16
msgid ""
"If called with a single class as its only positional argument and no "
"additional keyword arguments, it attaches the mark to the class so it gets "
"applied automatically to all test cases found in that class."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:20
msgid ""
"If called with a single function as its only positional argument and no "
"additional keyword arguments, it attaches the mark to the function, "
"containing all the arguments already stored internally in the "
"``MarkDecorator``."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:25
msgid ""
"When called in any other case, it returns a new ``MarkDecorator`` instance "
"with the original ``MarkDecorator``'s content updated with the arguments "
"passed to this call."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:29
msgid ""
"Note: The rules above prevent a ``MarkDecorator`` from storing only a single "
"function or class reference as its positional argument with no additional "
"keyword or positional arguments. You can work around this by using "
"`with_args()`."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of pytest.MarkDecorator.name:1
msgid "Alias for mark.name."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of pytest.MarkDecorator.args:1
msgid "Alias for mark.args."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
#: of pytest.MarkDecorator.kwargs:1
msgid "Alias for mark.kwargs."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/mark/structures.py:docstring
