#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:79
msgid "**Legacy form**"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:81
msgid "It is possible to specify a callable by passing a to-be-called lambda::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:83
msgid ""
">>> raises(ZeroDivisionError, lambda: 1/0)\n"
"<ExceptionInfo ...>"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:86
msgid "or you can specify an arbitrary callable with arguments::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:88
msgid ""
">>> def f(x): return 1/x\n"
"...\n"
">>> raises(ZeroDivisionError, f, 0)\n"
"<ExceptionInfo ...>\n"
">>> raises(ZeroDivisionError, f, x=0)\n"
"<ExceptionInfo ...>"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:95
msgid ""
"The form above is fully supported but discouraged for new code because the "
"context manager form is regarded as more readable and less error-prone."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:99
msgid ""
"Similar to caught exception objects in Python, explicitly clearing local "
"references to returned ``ExceptionInfo`` objects can help the Python "
"interpreter speed up its garbage collection."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:103
msgid ""
"Clearing those references breaks a reference cycle (``ExceptionInfo`` --> "
"caught exception --> frame stack raising the exception --> current frame "
"stack --> local variables --> ``ExceptionInfo``) which makes Python keep all "
"objects referenced from that cycle (including all local variables in the "
"current frame) alive until the next cyclic garbage collection run. More "
"detailed information can be found in the official Python documentation for :"
"ref:`the try statement <python:try>`."
msgstr ""

#: ../../../doc/en/reference/reference.rst:105
msgid "pytest.deprecated_call"
msgstr ""

#: ../../../doc/en/reference/reference.rst:107
msgid "**Tutorial**: :ref:`ensuring_function_triggers`"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.deprecated_call:1
msgid ""
"Assert that code produces a ``DeprecationWarning`` or "
"``PendingDeprecationWarning``."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.deprecated_call:3
msgid "This function can be used as a context manager::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.deprecated_call:5
msgid ""
">>> import warnings\n"
">>> def api_call_v2():\n"
"...     warnings.warn('use v3 of this api', DeprecationWarning)\n"
"...     return 200\n"
"\n"
">>> import pytest\n"
">>> with pytest.deprecated_call():\n"
"...    assert api_call_v2() == 200"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.deprecated_call:14
msgid ""
"It can also be used by passing a function and ``*args`` and ``**kwargs``, in "
"which case it will ensure calling ``func(*args, **kwargs)`` produces one of "
"the warnings types above. The return value is the return value of the "
"function."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.deprecated_call:18
msgid ""
"In the context manager form you may use the keyword argument ``match`` to "
"assert that the warning matches a text or regex."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
#: of _pytest.recwarn.deprecated_call:21
msgid ""
"The context manager produces a list of :class:`warnings.WarningMessage` "
"objects, one for each warning raised."
