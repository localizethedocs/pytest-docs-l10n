msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:1
msgid "Assert that a code block/function call raises an exception."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:3
msgid ""
"The expected exception type, or a tuple if one of multiple possible "
"exception types are expected."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:6
msgid ""
"If specified, a string containing a regular expression, or a regular "
"expression object, that is tested against the string representation of the "
"exception using :func:`re.search`.  To match a literal string that may "
"contain :ref:`special characters <re-syntax>`, the pattern can first be "
"escaped with :func:`re.escape`.  (This is only used when :py:func:`pytest."
"raises` is used as a context manager, and passed through to the function "
"otherwise. When using :py:func:`pytest.raises` as a function, you can use: "
"``pytest.raises(Exc, func, match=\"passed on\").match(\"my pattern\")``.)"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:7
msgid ""
"If specified, a string containing a regular expression, or a regular "
"expression object, that is tested against the string representation of the "
"exception using :func:`re.search`."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:11
msgid ""
"To match a literal string that may contain :ref:`special characters <re-"
"syntax>`, the pattern can first be escaped with :func:`re.escape`."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:14
msgid ""
"(This is only used when :py:func:`pytest.raises` is used as a context "
"manager, and passed through to the function otherwise. When using :py:func:"
"`pytest.raises` as a function, you can use: ``pytest.raises(Exc, func, "
"match=\"passed on\").match(\"my pattern\")``.)"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:21
msgid ""
"Use ``pytest.raises`` as a context manager, which will capture the exception "
"of the given type::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:24
msgid ""
">>> import pytest\n"
">>> with pytest.raises(ZeroDivisionError):\n"
"...    1/0"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:28
msgid ""
"If the code block does not raise the expected exception "
"(``ZeroDivisionError`` in the example above), or no exception at all, the "
"check will fail instead."
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:31
msgid ""
"You can also use the keyword argument ``match`` to assert that the exception "
"matches a text or regex::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:34
msgid ""
">>> with pytest.raises(ValueError, match='must be 0 or None'):\n"
"...     raise ValueError(\"value must be 0 or None\")\n"
"\n"
">>> with pytest.raises(ValueError, match=r'must be \\d+$'):\n"
"...     raise ValueError(\"value must be 42\")"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:40
msgid ""
"The context manager produces an :class:`ExceptionInfo` object which can be "
"used to inspect the details of the captured exception::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:43
msgid ""
">>> with pytest.raises(ValueError) as exc_info:\n"
"...     raise ValueError(\"value must be 42\")\n"
">>> assert exc_info.type is ValueError\n"
">>> assert exc_info.value.args[0] == \"value must be 42\""
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:50
msgid ""
"When using ``pytest.raises`` as a context manager, it's worthwhile to note "
"that normal context manager rules apply and that the exception raised *must* "
"be the final line in the scope of the context manager. Lines of code after "
"that, within the scope of the context manager will not be executed. For "
"example::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:56
msgid ""
">>> value = 15\n"
">>> with pytest.raises(ValueError) as exc_info:\n"
"...     if value > 10:\n"
"...         raise ValueError(\"value must be <= 10\")\n"
"...     assert exc_info.type is ValueError  # this will not execute"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:62
msgid ""
"Instead, the following approach must be taken (note the difference in "
"scope)::"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:65
msgid ""
">>> with pytest.raises(ValueError) as exc_info:\n"
"...     if value > 10:\n"
"...         raise ValueError(\"value must be <= 10\")\n"
"...\n"
">>> assert exc_info.type is ValueError"
msgstr ""

#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/python_api.py:docstring
#: of _pytest.python_api.raises:71
#: ../../../../../.conda/lib/python3.12/site-packages/_pytest/recwarn.py:docstring
