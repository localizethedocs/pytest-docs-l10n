msgid ""
"`#3988 <https://github.com/pytest-dev/pytest/issues/3988>`_: Add a "
"Deprecation warning for pytest.ensuretemp as it was deprecated since a while."
msgstr ""

#: ../../../CHANGELOG.rst:240
msgid ""
