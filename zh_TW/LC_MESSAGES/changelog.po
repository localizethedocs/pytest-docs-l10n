#: ../../../CHANGELOG.rst:3082 ../../../CHANGELOG.rst:3187
#: ../../../CHANGELOG.rst:5086
msgid "**Bug Fixes**"
msgstr ""

#: ../../../CHANGELOG.rst:2900
msgid "Parametrize now correctly handles duplicated test ids."
msgstr ""

#: ../../../CHANGELOG.rst:2902
msgid ""
"Fix internal error issue when the ``method`` argument is missing for "
"``teardown_method()`` (`#1605`_)."
msgstr ""

#: ../../../CHANGELOG.rst:2905
msgid ""
"Fix exception visualization in case the current working directory (CWD) gets "
"deleted during testing (`#1235`_). Thanks `@bukzor`_ for reporting. PR by "
"`@marscher`_."
msgstr ""

#: ../../../CHANGELOG.rst:2909
msgid ""
"Improve test output for logical expression with brackets (`#925`_). Thanks "
"`@DRMacIver`_ for reporting and `@RedBeardCode`_ for the PR."
msgstr ""

#: ../../../CHANGELOG.rst:2912
msgid ""
"Create correct diff for strings ending with newlines (`#1553`_). Thanks "
"`@Vogtinator`_ for reporting and `@RedBeardCode`_ and `@tomviner`_ for the "
"PR."
msgstr ""

#: ../../../CHANGELOG.rst:2916
msgid ""
"``ConftestImportFailure`` now shows the traceback making it easier to "
"identify bugs in ``conftest.py`` files (`#1516`_). Thanks `@txomon`_ for the "
"PR."
msgstr ""

#: ../../../CHANGELOG.rst:2923
msgid ""
"Fixed collection of classes with custom ``__new__`` method. Fixes `#1579`_. "
"Thanks to `@Stranger6667`_ for the PR."
msgstr ""

#: ../../../CHANGELOG.rst:2926
msgid ""
"Fixed scope overriding inside metafunc.parametrize (`#634`_). Thanks to "
"`@Stranger6667`_ for the PR."
msgstr ""

#: ../../../CHANGELOG.rst:2929
msgid ""
"Fixed the total tests tally in junit xml output (`#1798`_). Thanks to "
"`@cryporchild`_ for the PR."
msgstr ""

#: ../../../CHANGELOG.rst:2932
msgid ""
"Fixed off-by-one error with lines from ``request.node.warn``. Thanks to "
"`@blueyed`_ for the PR."
msgstr ""

#: ../../../CHANGELOG.rst:3041
msgid "2.9.2 (2016-05-31)"
msgstr ""

#: ../../../CHANGELOG.rst:3045
msgid ""
"fix `#510`_: skip tests where one parameterize dimension was empty thanks "
"Alex Stapleton for the Report and `@RonnyPfannschmidt`_ for the PR"
msgstr ""

#: ../../../CHANGELOG.rst:3048
msgid ""
"Fix Xfail does not work with condition keyword argument. Thanks `@astraw38`_ "
"for reporting the issue (`#1496`_) and `@tomviner`_ for PR the (`#1524`_)."
msgstr ""

#: ../../../CHANGELOG.rst:3052
msgid ""
"Fix win32 path issue when putting custom config file with absolute path in "
"``pytest.main(\"-c your_absolute_path\")``."
