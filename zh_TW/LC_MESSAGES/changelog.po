msgstr ""

#: ../../../CHANGELOG.rst:1230
msgid ""
"fix issue181: --pdb now also works on collect errors (and on internal "
"errors) .  This was implemented by a slight internal refactoring and the "
"introduction of a new hook ``pytest_exception_interact`` hook (see next "
"item)."
msgstr ""

#: ../../../CHANGELOG.rst:1235
msgid ""
