#: ../../../doc/en/tmpdir.rst:6
msgid "Temporary directories and files"
msgstr ""

#: ../../../doc/en/tmpdir.rst:9
msgid "The ``tmp_path`` fixture"
msgstr ""

#: ../../../doc/en/tmpdir.rst:14
msgid ""
"You can use the ``tmp_path`` fixture which will provide a temporary "
"directory unique to the test invocation, created in the `base temporary "
"directory`_."
msgstr ""

#: ../../../doc/en/tmpdir.rst:18
msgid ""
"``tmp_path`` is a ``pathlib.Path`` object. Here is an example test usage:"
msgstr ""

#: ../../../doc/en/tmpdir.rst:20
msgid ""
"# content of test_tmp_path.py\n"
"CONTENT = \"content\"\n"
"\n"
"\n"
"def test_create_file(tmp_path):\n"
"    d = tmp_path / \"sub\"\n"
"    d.mkdir()\n"
"    p = d / \"hello.txt\"\n"
"    p.write_text(CONTENT)\n"
"    assert p.read_text() == CONTENT\n"
"    assert len(list(tmp_path.iterdir())) == 1\n"
"    assert 0"
msgstr ""

#: ../../../doc/en/tmpdir.rst:35 ../../../doc/en/tmpdir.rst:105
msgid ""
"Running this would result in a passed test except for the last ``assert 0`` "
"line which we use to look at values:"
msgstr ""

#: ../../../doc/en/tmpdir.rst:38
msgid ""
"$ pytest test_tmp_path.py\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-6.x.y, py-1.x.y, pluggy-1.x.y\n"
"cachedir: $PYTHON_PREFIX/.pytest_cache\n"
"rootdir: $REGENDOC_TMPDIR\n"
"collected 1 item\n"
"\n"
"test_tmp_path.py F                                                   [100%]\n"
"\n"
"================================= FAILURES "
"=================================\n"
"_____________________________ test_create_file "
"_____________________________\n"
"\n"
"tmp_path = PosixPath('PYTEST_TMPDIR/test_create_file0')\n"
"\n"
"    def test_create_file(tmp_path):\n"
"        d = tmp_path / \"sub\"\n"
"        d.mkdir()\n"
"        p = d / \"hello.txt\"\n"
"        p.write_text(CONTENT)\n"
"        assert p.read_text() == CONTENT\n"
"        assert len(list(tmp_path.iterdir())) == 1\n"
">       assert 0\n"
"E       assert 0\n"
"\n"
"test_tmp_path.py:11: AssertionError\n"
"========================= short test summary info "
"==========================\n"
"FAILED test_tmp_path.py::test_create_file - assert 0\n"
"============================ 1 failed in 0.12s ============================="
msgstr ""

#: ../../../doc/en/tmpdir.rst:72
msgid "The ``tmp_path_factory`` fixture"
msgstr ""

#: ../../../doc/en/tmpdir.rst:77
msgid ""
"The ``tmp_path_factory`` is a session-scoped fixture which can be used to "
"create arbitrary temporary directories from any other fixture or test."
msgstr ""

#: ../../../doc/en/tmpdir.rst:80
msgid ""
"It is intended to replace ``tmpdir_factory``, and returns :class:`pathlib."
"Path` instances."
msgstr ""

#: ../../../doc/en/tmpdir.rst:82
msgid ""
"See :ref:`tmp_path_factory API <tmp_path_factory factory api>` for details."
msgstr ""

#: ../../../doc/en/tmpdir.rst:86
msgid "The 'tmpdir' fixture"
msgstr ""

#: ../../../doc/en/tmpdir.rst:88
msgid ""
"You can use the ``tmpdir`` fixture which will provide a temporary directory "
"unique to the test invocation, created in the `base temporary directory`_."
msgstr ""

#: ../../../doc/en/tmpdir.rst:92
msgid ""
"``tmpdir`` is a `py.path.local`_ object which offers ``os.path`` methods and "
"more.  Here is an example test usage:"
msgstr ""

#: ../../../doc/en/tmpdir.rst:95
msgid ""
"# content of test_tmpdir.py\n"
"def test_create_file(tmpdir):\n"
"    p = tmpdir.mkdir(\"sub\").join(\"hello.txt\")\n"
"    p.write(\"content\")\n"
"    assert p.read() == \"content\"\n"
"    assert len(tmpdir.listdir()) == 1\n"
"    assert 0"
msgstr ""

#: ../../../doc/en/tmpdir.rst:108
msgid ""
"$ pytest test_tmpdir.py\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-6.x.y, py-1.x.y, pluggy-1.x.y\n"
"cachedir: $PYTHON_PREFIX/.pytest_cache\n"
"rootdir: $REGENDOC_TMPDIR\n"
"collected 1 item\n"
"\n"
"test_tmpdir.py F                                                     [100%]\n"
"\n"
"================================= FAILURES "
"=================================\n"
"_____________________________ test_create_file "
"_____________________________\n"
"\n"
"tmpdir = local('PYTEST_TMPDIR/test_create_file0')\n"
"\n"
"    def test_create_file(tmpdir):\n"
"        p = tmpdir.mkdir(\"sub\").join(\"hello.txt\")\n"
"        p.write(\"content\")\n"
"        assert p.read() == \"content\"\n"
"        assert len(tmpdir.listdir()) == 1\n"
">       assert 0\n"
"E       assert 0\n"
"\n"
"test_tmpdir.py:6: AssertionError\n"
"========================= short test summary info "
"==========================\n"
"FAILED test_tmpdir.py::test_create_file - assert 0\n"
"============================ 1 failed in 0.12s ============================="
msgstr ""

#: ../../../doc/en/tmpdir.rst:140
msgid "The 'tmpdir_factory' fixture"
msgstr ""

#: ../../../doc/en/tmpdir.rst:144
msgid ""
"The ``tmpdir_factory`` is a session-scoped fixture which can be used to "
"create arbitrary temporary directories from any other fixture or test."
msgstr ""

#: ../../../doc/en/tmpdir.rst:147
msgid ""
"For example, suppose your test suite needs a large image on disk, which is "
"generated procedurally. Instead of computing the same image for each test "
"that uses it into its own ``tmpdir``, you can generate it once per-session "
"to save time:"
msgstr ""

#: ../../../doc/en/tmpdir.rst:152
msgid ""
"# contents of conftest.py\n"
"import pytest\n"
"\n"
"\n"
"@pytest.fixture(scope=\"session\")\n"
"def image_file(tmpdir_factory):\n"
"    img = compute_expensive_image()\n"
"    fn = tmpdir_factory.mktemp(\"data\").join(\"img.png\")\n"
"    img.save(str(fn))\n"
"    return fn\n"
"\n"
"\n"
"# contents of test_image.py\n"
"def test_histogram(image_file):\n"
"    img = load_image(image_file)\n"
"    # compute and test histogram"
msgstr ""

#: ../../../doc/en/tmpdir.rst:171
msgid "See :ref:`tmpdir_factory API <tmpdir factory api>` for details."
msgstr ""

#: ../../../doc/en/tmpdir.rst:177
msgid "The default base temporary directory"
msgstr ""

#: ../../../doc/en/tmpdir.rst:179
msgid ""
"Temporary directories are by default created as sub-directories of the "
"system temporary directory.  The base name will be ``pytest-NUM`` where "
"``NUM`` will be incremented with each test run.  Moreover, entries older "
"than 3 temporary directories will be removed."
msgstr ""

#: ../../../doc/en/tmpdir.rst:184
msgid "You can override the default temporary directory setting like this:"
msgstr ""

#: ../../../doc/en/tmpdir.rst:186
msgid "pytest --basetemp=mydir"
msgstr ""

#: ../../../doc/en/tmpdir.rst:192
msgid ""
"The contents of ``mydir`` will be completely removed, so make sure to use a "
"directory for that purpose only."
msgstr ""

#: ../../../doc/en/tmpdir.rst:195
msgid ""
"When distributing tests on the local machine using ``pytest-xdist``, care is "
"taken to automatically configure a basetemp directory for the sub processes "
"such that all temporary data lands below a single per-test run basetemp "
"directory."
msgstr ""
