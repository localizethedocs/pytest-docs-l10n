#: ../../../doc/en/index.rst:6
msgid "pytest: helps you write better programs"
msgstr ""

#: ../../../doc/en/index.rst:9
msgid ""
"The ``pytest`` framework makes it easy to write small tests, yet scales to "
"support complex functional testing for applications and libraries."
msgstr ""

#: ../../../doc/en/index.rst:12
msgid "An example of a simple test:"
msgstr ""

#: ../../../doc/en/index.rst:14
msgid ""
"# content of test_sample.py\n"
"def inc(x):\n"
"    return x + 1\n"
"\n"
"\n"
"def test_answer():\n"
"    assert inc(3) == 5"
msgstr ""

#: ../../../doc/en/index.rst:25
msgid "To execute it:"
msgstr ""

#: ../../../doc/en/index.rst:27
msgid ""
"$ pytest\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-4.x.y, py-1.x.y, pluggy-0.x.y\n"
"cachedir: $PYTHON_PREFIX/.pytest_cache\n"
"rootdir: $REGENDOC_TMPDIR\n"
"collected 1 item\n"
"\n"
"test_sample.py F                                                     [100%]\n"
"\n"
"================================= FAILURES "
"=================================\n"
"_______________________________ test_answer "
"________________________________\n"
"\n"
"    def test_answer():\n"
">       assert inc(3) == 5\n"
"E       assert 4 == 5\n"
"E        +  where 4 = inc(3)\n"
"\n"
"test_sample.py:6: AssertionError\n"
"========================= 1 failed in 0.12 seconds ========================="
msgstr ""

#: ../../../doc/en/index.rst:49
msgid ""
"Due to ``pytest``'s detailed assertion introspection, only plain ``assert`` "
"statements are used. See :ref:`Getting Started <getstarted>` for more "
"examples."
msgstr ""

