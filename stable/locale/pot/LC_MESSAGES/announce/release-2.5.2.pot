#: ../../../doc/en/announce/release-2.5.2.rst:41
msgid ""
"fix issue409 -- better interoperate with cx_freeze by not trying to import "
"from collections.abc which causes problems for py27/cx_freeze.  Thanks "
"Wolfgang L. for reporting and tracking it down."
msgstr ""

#: ../../../doc/en/announce/release-2.5.2.rst:45
msgid ""
"fixed docs and code to use \"pytest\" instead of \"py.test\" almost "
"everywhere. Thanks Jurko Gospodnetic for the complete PR."
msgstr ""

#: ../../../doc/en/announce/release-2.5.2.rst:48
msgid ""
"fix issue425: mention at end of \"py.test -h\" that --markers and --fixtures "
"work according to specified test path (or current dir)"
msgstr ""

#: ../../../doc/en/announce/release-2.5.2.rst:51
msgid ""
"fix issue413: exceptions with unicode attributes are now printed correctly "
"also on python2 and with pytest-xdist runs. (the fix requires py-1.4.20)"
msgstr ""

#: ../../../doc/en/announce/release-2.5.2.rst:55
msgid ""
"copy, cleanup and integrate py.io capture from pylib 1.4.20.dev2 (rev "
"13d9af95547e)"
msgstr ""

#: ../../../doc/en/announce/release-2.5.2.rst:58
msgid "address issue416: clarify docs as to conftest.py loading semantics"
msgstr ""

#: ../../../doc/en/announce/release-2.5.2.rst:60
msgid ""
"fix issue429: comparing byte strings with non-ascii chars in assert "
"expressions now work better.  Thanks Floris Bruynooghe."
msgstr ""

#: ../../../doc/en/announce/release-2.5.2.rst:63
msgid "make capfd/capsys.capture private, its unused and shouldn't be exposed"
msgstr ""
