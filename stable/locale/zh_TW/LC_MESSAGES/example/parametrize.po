msgstr ""
"$ pytest -v test_indirect_list.py\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-9.x.y, pluggy-1.x.y -- $PYTHON_PREFIX/"
"bin/python\n"
