#: ../../../doc/en/example/parametrize.rst:512
msgid "Parametrization of optional implementations/imports"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:514
msgid ""
"If you want to compare the outcomes of several implementations of a given "
"API, you can write test functions that receive the already imported "
"implementations and get skipped in case the implementation is not importable/"
"available.  Let's say we have a \"base\" implementation and the other "
"(possibly optimized ones) need to provide similar results:"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:520
msgid ""
"# content of conftest.py\n"
"\n"
"import pytest\n"
"\n"
"\n"
"@pytest.fixture(scope=\"session\")\n"
"def basemod(request):\n"
"    return pytest.importorskip(\"base\")\n"
"\n"
"\n"
"@pytest.fixture(scope=\"session\", params=[\"opt1\", \"opt2\"])\n"
"def optmod(request):\n"
"    return pytest.importorskip(request.param)"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:536
msgid "And then a base implementation of a simple function:"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:538
msgid ""
"# content of base.py\n"
"def func1():\n"
"    return 1"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:544
msgid "And an optimized version:"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:546
msgid ""
"# content of opt1.py\n"
"def func1():\n"
"    return 1.0001"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:552
msgid "And finally a little test module:"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:554
msgid ""
"# content of test_module.py\n"
"\n"
"\n"
"def test_func1(basemod, optmod):\n"
"    assert round(basemod.func1(), 3) == round(optmod.func1(), 3)"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:563
msgid "If you run this with reporting for skips enabled:"
msgstr ""

#: ../../../doc/en/example/parametrize.rst:565
