"mark1 = pytest.mark.NAME              # simple MarkDecorator\n"
"mark2 = pytest.mark.NAME(name1=value) # parametrized MarkDecorator"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:7
msgid "and can then be applied as decorators to test functions::"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:9
msgid ""
"@mark2\n"
"def test_function():\n"
"    pass"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:13
msgid "When a MarkDecorator instance is called it does the following:"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:15
msgid ""
"If called with a single class as its only positional argument and no "
"additional keyword arguments, it attaches itself to the class so it gets "
"applied automatically to all test cases found in that class."
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:18
msgid ""
"If called with a single function as its only positional argument and no "
"additional keyword arguments, it attaches a MarkInfo object to the function, "
"containing all the arguments already stored internally in the MarkDecorator."
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:22
msgid ""
"When called in any other case, it performs a 'fake construction' call, i.e. "
"it returns a new MarkDecorator instance with the original MarkDecorator's "
"content updated with the arguments passed to this call."
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.structures.MarkDecorator:27
msgid ""
"Note: The rules above prevent MarkDecorator objects from storing only a "
"single function or class reference as their positional argument with no "
"additional keyword or positional arguments."
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.MarkDecorator.name:1
msgid "alias for mark.name"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/mark/structures.py:docstring
#: of _pytest.mark.MarkDecorator.args:1
msgid "alias for mark.args"
msgstr ""

