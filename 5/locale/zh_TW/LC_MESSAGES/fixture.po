#: ../../../doc/en/fixture.rst:901
msgid "Using marks with parametrized fixtures"
msgstr ""

#: ../../../doc/en/fixture.rst:903
msgid ""
":func:`pytest.param` can be used to apply marks in values sets of "
"parametrized fixtures in the same way that they can be used with :ref:"
"`@pytest.mark.parametrize <@pytest.mark.parametrize>`."
msgstr ""

#: ../../../doc/en/fixture.rst:906
msgid "Example:"
msgstr ""

#: ../../../doc/en/fixture.rst:908
msgid ""
"# content of test_fixture_marks.py\n"
"import pytest\n"
"\n"
"\n"
"@pytest.fixture(params=[0, 1, pytest.param(2, marks=pytest.mark.skip)])\n"
"def data_set(request):\n"
"    return request.param\n"
"\n"
"\n"
"def test_data(data_set):\n"
"    pass"
msgstr ""

#: ../../../doc/en/fixture.rst:922
msgid ""
"Running this test will *skip* the invocation of ``data_set`` with value "
"``2``:"
msgstr ""

#: ../../../doc/en/fixture.rst:924
msgid ""
"$ pytest test_fixture_marks.py -v\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-5.x.y, py-1.x.y, pluggy-0.x.y -- "
"$PYTHON_PREFIX/bin/python\n"
"cachedir: $PYTHON_PREFIX/.pytest_cache\n"
"rootdir: $REGENDOC_TMPDIR\n"
