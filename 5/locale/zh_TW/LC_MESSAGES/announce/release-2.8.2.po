#: ../../../doc/en/announce/release-2.8.2.rst:33
msgid ""
"fix #1085: proper handling of encoding errors when passing encoded byte "
"strings to pytest.parametrize in Python 2. Thanks Themanwithoutaplan for the "
"report and Bruno Oliveira for the PR."
msgstr ""

#: ../../../doc/en/announce/release-2.8.2.rst:37
msgid ""
"fix #1087: handling SystemError when passing empty byte strings to pytest."
"parametrize in Python 3. Thanks Paul Kehrer for the report and Bruno "
"Oliveira for the PR."
msgstr ""

#: ../../../doc/en/announce/release-2.8.2.rst:41
msgid ""
"fix #995: fixed internal error when filtering tracebacks where one entry was "
"generated by an exec() statement. Thanks Daniel Hahler, Ashley C Straw, "
"Philippe Gauthier and Pavel Savchenko for contributing and Bruno Oliveira "
"for the PR."
msgstr ""
