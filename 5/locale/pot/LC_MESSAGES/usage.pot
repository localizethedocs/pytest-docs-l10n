#: ../../../doc/en/usage.rst:5
msgid "Usage and Invocations"
msgstr ""

#: ../../../doc/en/usage.rst:11
msgid "Calling pytest through ``python -m pytest``"
msgstr ""

#: ../../../doc/en/usage.rst:15
msgid ""
"You can invoke testing through the Python interpreter from the command line:"
msgstr ""

#: ../../../doc/en/usage.rst:17
msgid "python -m pytest [...]"
msgstr ""

#: ../../../doc/en/usage.rst:21
msgid ""
"This is almost equivalent to invoking the command line script ``pytest "
"[...]`` directly, except that calling via ``python`` will also add the "
"current directory to ``sys.path``."
msgstr ""

#: ../../../doc/en/usage.rst:25
msgid "Possible exit codes"
msgstr ""

