#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/python.py:docstring
#: of _pytest.python.raises:14
msgid ""
"When using ``pytest.raises`` as a context manager, it's worthwhile to note "
"that normal context manager rules apply and that the exception raised *must* "
"be the final line in the scope of the context manager. Lines of code after "
"that, within the scope of the context manager will not be executed. For "
"example::"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/python.py:docstring
#: of _pytest.python.raises:20
msgid ""
">>> with raises(OSError) as exc_info:\n"
"        assert 1 == 1  # this will execute as expected\n"
"        raise OSError(errno.EEXISTS, 'directory exists')\n"
"        assert exc_info.value.errno == errno.EEXISTS  # this will not execute"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/python.py:docstring
#: of _pytest.python.raises:25
msgid ""
"Instead, the following approach must be taken (note the difference in "
"scope)::"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/python.py:docstring
#: of _pytest.python.raises:28
msgid ""
">>> with raises(OSError) as exc_info:\n"
"        assert 1 == 1  # this will execute as expected\n"
"        raise OSError(errno.EEXISTS, 'directory exists')\n"
"\n"
"    assert exc_info.value.errno == errno.EEXISTS  # this will now execute"
msgstr ""

#: ../../../../../.conda/lib/python3.8/site-packages/_pytest/python.py:docstring
