#: ../../../doc/en/changelog.rst:8510
msgid "refined usage and options for \"py.cleanup\"::"
msgstr ""

#: ../../../doc/en/changelog.rst:8512
msgid ""
"py.cleanup     # remove \"*.pyc\" and \"*$py.class\" (jython) files\n"
"py.cleanup -e .swp -e .cache # also remove files with these extensions\n"
"py.cleanup -s  # remove \"build\" and \"dist\" directory next to setup.py "
"files\n"
"py.cleanup -d  # also remove empty directories\n"
"py.cleanup -a  # synonym for \"-s -d -e 'pip-log.txt'\"\n"
"py.cleanup -n  # dry run, only show what would be removed"
