#: ../../../doc/en/changelog.rst:5434
msgid "Improved Documentation"
msgstr ""

#: ../../../doc/en/changelog.rst:279
msgid ""
"`#7429 <https://github.com/pytest-dev/pytest/issues/7429>`_: Add more "
"information and use cases about skipping doctests."
msgstr ""

#: ../../../doc/en/changelog.rst:282
msgid ""
"`#7780 <https://github.com/pytest-dev/pytest/issues/7780>`_: Classes which "
"should not be inherited from are now marked ``final class`` in the API "
"reference."
msgstr ""

#: ../../../doc/en/changelog.rst:285
msgid ""
"`#7872 <https://github.com/pytest-dev/pytest/issues/7872>`_: ``_pytest."
"config.argparsing.Parser.addini()`` accepts explicit ``None`` and "
"``\"string\"``."
msgstr ""

#: ../../../doc/en/changelog.rst:288
msgid ""
"`#7878 <https://github.com/pytest-dev/pytest/issues/7878>`_: In pull request "
"section, ask to commit after editing changelog and authors file."
msgstr ""

#: ../../../doc/en/changelog.rst:295
msgid ""
"`#7802 <https://github.com/pytest-dev/pytest/issues/7802>`_: The ``attrs`` "
"dependency requirement is now >=19.2.0 instead of >=17.4.0."
msgstr ""

#: ../../../doc/en/changelog.rst:298
msgid ""
"`#8014 <https://github.com/pytest-dev/pytest/issues/8014>`_: `.pyc` files "
"created by pytest's assertion rewriting now conform to the newer PEP-552 "
"format on Python>=3.7. (These files are internal and only interpreted by "
"pytest itself.)"
msgstr ""

#: ../../../doc/en/changelog.rst:303
msgid "pytest 6.1.2 (2020-10-28)"
msgstr ""

#: ../../../doc/en/changelog.rst:311
msgid ""
"`#7911 <https://github.com/pytest-dev/pytest/issues/7911>`_: Directories "
"created by `tmpdir` are now considered stale after 3 days without "
"modification (previous value was 3 hours) to avoid deleting directories "
"still in use in long running test suites."
msgstr ""

#: ../../../doc/en/changelog.rst:318
msgid ""
"`#7815 <https://github.com/pytest-dev/pytest/issues/7815>`_: Improve "
"deprecation warning message for ``pytest._fillfuncargs()``."
msgstr ""

#: ../../../doc/en/changelog.rst:322
msgid "pytest 6.1.1 (2020-10-03)"
msgstr ""

#: ../../../doc/en/changelog.rst:327
msgid ""
"`#7807 <https://github.com/pytest-dev/pytest/issues/7807>`_: Fixed "
"regression in pytest 6.1.0 causing incorrect rootdir to be determined in "
"some non-trivial cases where parent directories have config files as well."
msgstr ""

#: ../../../doc/en/changelog.rst:330
msgid ""
"`#7814 <https://github.com/pytest-dev/pytest/issues/7814>`_: Fixed crash in "
"header reporting when :confval:`testpaths` is used and contains absolute "
"paths (regression in 6.1.0)."
msgstr ""

#: ../../../doc/en/changelog.rst:334
msgid "pytest 6.1.0 (2020-09-26)"
msgstr ""

#: ../../../doc/en/changelog.rst:339
msgid ""
"`#5585 <https://github.com/pytest-dev/pytest/issues/5585>`_: As per our "
"policy, the following features which have been deprecated in the 5.X series "
"are now removed:"
msgstr ""

#: ../../../doc/en/changelog.rst:342
msgid ""
"The ``funcargnames`` read-only property of ``FixtureRequest``, ``Metafunc``, "
"and ``Function`` classes. Use ``fixturenames`` attribute."
msgstr ""

#: ../../../doc/en/changelog.rst:344
msgid ""
"``@pytest.fixture`` no longer supports positional arguments, pass all "
"arguments by keyword instead."
msgstr ""

#: ../../../doc/en/changelog.rst:346
msgid ""
"Direct construction of ``Node`` subclasses now raise an error, use "
"``from_parent`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:348
msgid ""
"The default value for ``junit_family`` has changed to ``xunit2``. If you "
"require the old format, add ``junit_family=xunit1`` to your configuration "
"file."
msgstr ""

#: ../../../doc/en/changelog.rst:350
msgid ""
"The ``TerminalReporter`` no longer has a ``writer`` attribute. Plugin "
"authors may use the public functions of the ``TerminalReporter`` instead of "
"accessing the ``TerminalWriter`` object directly."
msgstr ""

#: ../../../doc/en/changelog.rst:352
msgid ""
"The ``--result-log`` option has been removed. Users are recommended to use "
"the `pytest-reportlog <https://github.com/pytest-dev/pytest-reportlog>`__ "
"plugin instead."
msgstr ""

#: ../../../doc/en/changelog.rst:355 ../../../doc/en/changelog.rst:1797
msgid ""
"For more information consult `Deprecations and Removals <https://docs.pytest."
"org/en/stable/deprecations.html>`__ in the docs."
msgstr ""

#: ../../../doc/en/changelog.rst:363
msgid ""
"`#6981 <https://github.com/pytest-dev/pytest/issues/6981>`_: The ``pytest."
"collect`` module is deprecated: all its names can be imported from "
"``pytest`` directly."
msgstr ""

#: ../../../doc/en/changelog.rst:366
msgid ""
"`#7097 <https://github.com/pytest-dev/pytest/issues/7097>`_: The ``pytest."
"_fillfuncargs`` function is deprecated. This function was kept for backward "
"compatibility with an older plugin."
msgstr ""

#: ../../../doc/en/changelog.rst:369
msgid ""
"It's functionality is not meant to be used directly, but if you must replace "
"it, use `function._request._fillfixtures()` instead, though note this is not "
"a public API and may break in the future."
msgstr ""

#: ../../../doc/en/changelog.rst:374 ../../../doc/en/changelog.rst:725
msgid ""
"`#7210 <https://github.com/pytest-dev/pytest/issues/7210>`_: The special ``-"
"k '-expr'`` syntax to ``-k`` is deprecated. Use ``-k 'not expr'`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:377 ../../../doc/en/changelog.rst:728
msgid ""
"The special ``-k 'expr:'`` syntax to ``-k`` is deprecated. Please open an "
"issue if you use this and want a replacement."
msgstr ""

#: ../../../doc/en/changelog.rst:381
msgid ""
"`#7255 <https://github.com/pytest-dev/pytest/issues/7255>`_: The :func:"
"`pytest_warning_captured <_pytest.hookspec.pytest_warning_captured>` hook is "
"deprecated in favor of :func:`pytest_warning_recorded <_pytest.hookspec."
"pytest_warning_recorded>`, and will be removed in a future version."
msgstr ""

#: ../../../doc/en/changelog.rst:385
msgid ""
"`#7648 <https://github.com/pytest-dev/pytest/issues/7648>`_: The "
"``gethookproxy()`` and ``isinitpath()`` methods of ``FSCollector`` and "
"``Package`` are deprecated; use ``self.session.gethookproxy()`` and ``self."
"session.isinitpath()`` instead. This should work on all pytest versions."
msgstr ""

#: ../../../doc/en/changelog.rst:394
msgid ""
"`#7667 <https://github.com/pytest-dev/pytest/issues/7667>`_: New ``--"
"durations-min`` command-line flag controls the minimal duration for "
"inclusion in the slowest list of tests shown by ``--durations``. Previously "
"this was hard-coded to ``0.005s``."
msgstr ""

#: ../../../doc/en/changelog.rst:401
msgid ""
"`#6681 <https://github.com/pytest-dev/pytest/issues/6681>`_: Internal pytest "
"warnings issued during the early stages of initialization are now properly "
"handled and can filtered through :confval:`filterwarnings` or ``--"
"pythonwarnings/-W``."
msgstr ""

#: ../../../doc/en/changelog.rst:403
msgid ""
"This also fixes a number of long standing issues: `#2891 <https://github.com/"
"pytest-dev/pytest/issues/2891>`__, `#7620 <https://github.com/pytest-dev/"
"pytest/issues/7620>`__, `#7426 <https://github.com/pytest-dev/pytest/"
"issues/7426>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:406
msgid ""
"`#7572 <https://github.com/pytest-dev/pytest/issues/7572>`_: When a plugin "
"listed in ``required_plugins`` is missing or an unknown config key is used "
"with ``--strict-config``, a simple error message is now shown instead of a "
"stacktrace."
msgstr ""

#: ../../../doc/en/changelog.rst:409
msgid ""
"`#7685 <https://github.com/pytest-dev/pytest/issues/7685>`_: Added two new "
"attributes :attr:`rootpath <_pytest.config.Config.rootpath>` and :attr:"
"`inipath <_pytest.config.Config.inipath>` to :class:`Config <_pytest.config."
"Config>`. These attributes are :class:`pathlib.Path` versions of the "
"existing :attr:`rootdir <_pytest.config.Config.rootdir>` and :attr:`inifile "
"<_pytest.config.Config.inifile>` attributes, and should be preferred over "
"them when possible."
msgstr ""

#: ../../../doc/en/changelog.rst:414
msgid ""
"`#7780 <https://github.com/pytest-dev/pytest/issues/7780>`_: Public classes "
"which are not designed to be inherited from are now marked `@final <https://"
"docs.python.org/3/library/typing.html#typing.final>`_. Code which inherits "
"from these classes will trigger a type-checking (e.g. mypy) error, but will "
"still work in runtime. Currently the ``final`` designation does not appear "
"in the API Reference but hopefully will in the future."
msgstr ""

#: ../../../doc/en/changelog.rst:423
msgid ""
"`#1953 <https://github.com/pytest-dev/pytest/issues/1953>`_: Fixed error "
"when overwriting a parametrized fixture, while also reusing the super "
"fixture value."
msgstr ""

#: ../../../doc/en/changelog.rst:425
msgid ""
"# conftest.py\n"
"import pytest\n"
"\n"
"\n"
"@pytest.fixture(params=[1, 2])\n"
"def foo(request):\n"
"    return request.param\n"
"\n"
"\n"
"# test_foo.py\n"
"import pytest\n"
"\n"
"\n"
"@pytest.fixture\n"
"def foo(foo):\n"
"    return foo * 2"
msgstr ""

#: ../../../doc/en/changelog.rst:445
msgid ""
"`#4984 <https://github.com/pytest-dev/pytest/issues/4984>`_: Fixed an "
"internal error crash with ``IndexError: list index out of range`` when "
"collecting a module which starts with a decorated function, the decorator "
"raises, and assertion rewriting is enabled."
msgstr ""

#: ../../../doc/en/changelog.rst:450
msgid ""
"`#7591 <https://github.com/pytest-dev/pytest/issues/7591>`_: pylint "
"shouldn't complain anymore about unimplemented abstract methods when "
"inheriting from :ref:`File <non-python tests>`."
msgstr ""

#: ../../../doc/en/changelog.rst:453
msgid ""
"`#7628 <https://github.com/pytest-dev/pytest/issues/7628>`_: Fixed test "
"collection when a full path without a drive letter was passed to pytest on "
"Windows (for example ``\\projects\\tests\\test.py`` instead of ``c:"
"\\projects\\tests\\pytest.py``)."
msgstr ""

#: ../../../doc/en/changelog.rst:456
msgid ""
"`#7638 <https://github.com/pytest-dev/pytest/issues/7638>`_: Fix handling of "
"command-line options that appear as paths but trigger an OS-level syntax "
"error on Windows, such as the options used internally by ``pytest-xdist``."
msgstr ""

#: ../../../doc/en/changelog.rst:459
msgid ""
"`#7742 <https://github.com/pytest-dev/pytest/issues/7742>`_: Fixed "
"INTERNALERROR when accessing locals / globals with faulty ``exec``."
msgstr ""

#: ../../../doc/en/changelog.rst:466
msgid ""
"`#1477 <https://github.com/pytest-dev/pytest/issues/1477>`_: Removed faq.rst "
"and its reference in contents.rst."
msgstr ""

#: ../../../doc/en/changelog.rst:473
msgid ""
"`#7536 <https://github.com/pytest-dev/pytest/issues/7536>`_: The internal "
"``junitxml`` plugin has rewritten to use ``xml.etree.ElementTree``. The "
"order of attributes in XML elements might differ. Some unneeded escaping is "
"no longer performed."
msgstr ""

#: ../../../doc/en/changelog.rst:478
msgid ""
"`#7587 <https://github.com/pytest-dev/pytest/issues/7587>`_: The dependency "
"on the ``more-itertools`` package has been removed."
msgstr ""

#: ../../../doc/en/changelog.rst:481
msgid ""
"`#7631 <https://github.com/pytest-dev/pytest/issues/7631>`_: The result type "
"of :meth:`capfd.readouterr() <_pytest.capture.CaptureFixture.readouterr>` "
"(and similar) is no longer a namedtuple, but should behave like one in all "
"respects. This was done for technical reasons."
msgstr ""

#: ../../../doc/en/changelog.rst:485
msgid ""
"`#7671 <https://github.com/pytest-dev/pytest/issues/7671>`_: When collecting "
"tests, pytest finds test classes and functions by examining the attributes "
"of python objects (modules, classes and instances). To speed up this "
"process, pytest now ignores builtin attributes (like ``__class__``, "
"``__delattr__`` and ``__new__``) without consulting the :confval:"
"`python_classes` and :confval:`python_functions` configuration options and "
"without passing them to plugins using the :func:`pytest_pycollect_makeitem "
"<_pytest.hookspec.pytest_pycollect_makeitem>` hook."
msgstr ""

#: ../../../doc/en/changelog.rst:494
msgid "pytest 6.0.2 (2020-09-04)"
msgstr ""

#: ../../../doc/en/changelog.rst:499
msgid ""
"`#7148 <https://github.com/pytest-dev/pytest/issues/7148>`_: Fixed ``--log-"
"cli`` potentially causing unrelated ``print`` output to be swallowed."
msgstr ""

#: ../../../doc/en/changelog.rst:502
msgid ""
"`#7672 <https://github.com/pytest-dev/pytest/issues/7672>`_: Fixed log-"
"capturing level restored incorrectly if ``caplog.set_level`` is called more "
"than once."
msgstr ""

#: ../../../doc/en/changelog.rst:505
msgid ""
"`#7686 <https://github.com/pytest-dev/pytest/issues/7686>`_: Fixed "
"`NotSetType.token` being used as the parameter ID when the parametrization "
"list is empty. Regressed in pytest 6.0.0."
msgstr ""

#: ../../../doc/en/changelog.rst:509
msgid ""
"`#7707 <https://github.com/pytest-dev/pytest/issues/7707>`_: Fix internal "
"error when handling some exceptions that contain multiple lines or the style "
"uses multiple lines (``--tb=line`` for example)."
msgstr ""

#: ../../../doc/en/changelog.rst:513
msgid "pytest 6.0.1 (2020-07-30)"
msgstr ""

#: ../../../doc/en/changelog.rst:518
msgid ""
"`#7394 <https://github.com/pytest-dev/pytest/issues/7394>`_: Passing an "
"empty ``help`` value to ``Parser.add_option`` is now accepted instead of "
"crashing when running ``pytest --help``. Passing ``None`` raises a more "
"informative ``TypeError``."
msgstr ""

#: ../../../doc/en/changelog.rst:522
msgid ""
"`#7558 <https://github.com/pytest-dev/pytest/issues/7558>`_: Fix pylint "
"``not-callable`` lint on ``pytest.mark.parametrize()`` and the other builtin "
"marks: ``skip``, ``skipif``, ``xfail``, ``usefixtures``, ``filterwarnings``."
msgstr ""

#: ../../../doc/en/changelog.rst:526
msgid ""
"`#7559 <https://github.com/pytest-dev/pytest/issues/7559>`_: Fix regression "
"in plugins using ``TestReport.longreprtext`` (such as ``pytest-html``) when "
"``TestReport.longrepr`` is not a string."
msgstr ""

#: ../../../doc/en/changelog.rst:529
msgid ""
"`#7569 <https://github.com/pytest-dev/pytest/issues/7569>`_: Fix logging "
"capture handler's level not reset on teardown after a call to ``caplog."
"set_level()``."
msgstr ""

#: ../../../doc/en/changelog.rst:533
msgid "pytest 6.0.0 (2020-07-28)"
msgstr ""

#: ../../../doc/en/changelog.rst:535
msgid ""
"(**Please see the full set of changes for this release also in the 6.0.0rc1 "
"notes below**)"
msgstr ""

#: ../../../doc/en/changelog.rst:540
msgid ""
"`#5584 <https://github.com/pytest-dev/pytest/issues/5584>`_: "
"**PytestDeprecationWarning are now errors by default.**"
msgstr ""

#: ../../../doc/en/changelog.rst:542 ../../../doc/en/changelog.rst:1968
msgid ""
"Following our plan to remove deprecated features with as little disruption "
"as possible, all warnings of type ``PytestDeprecationWarning`` now generate "
"errors instead of warning messages."
msgstr ""

#: ../../../doc/en/changelog.rst:546
msgid ""
"**The affected features will be effectively removed in pytest 6.1**, so "
"please consult the `Deprecations and Removals <https://docs.pytest.org/en/"
"latest/deprecations.html>`__ section in the docs for directions on how to "
"update existing code."
msgstr ""

#: ../../../doc/en/changelog.rst:550
msgid ""
"In the pytest ``6.0.X`` series, it is possible to change the errors back "
"into warnings as a stopgap measure by adding this to your ``pytest.ini`` "
"file:"
msgstr ""

#: ../../../doc/en/changelog.rst:553 ../../../doc/en/changelog.rst:1979
msgid ""
"[pytest]\n"
"filterwarnings =\n"
"    ignore::pytest.PytestDeprecationWarning"
msgstr ""

#: ../../../doc/en/changelog.rst:559
msgid "But this will stop working when pytest ``6.1`` is released."
msgstr ""

#: ../../../doc/en/changelog.rst:561
msgid ""
"**If you have concerns** about the removal of a specific feature, please add "
"a comment to `#5584 <https://github.com/pytest-dev/pytest/issues/5584>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:565
msgid ""
"`#7472 <https://github.com/pytest-dev/pytest/issues/7472>`_: The ``exec_()`` "
"and ``is_true()`` methods of ``_pytest._code.Frame`` have been removed."
msgstr ""

#: ../../../doc/en/changelog.rst:572
msgid ""
"`#7464 <https://github.com/pytest-dev/pytest/issues/7464>`_: Added support "
"for :envvar:`NO_COLOR` and :envvar:`FORCE_COLOR` environment variables to "
"control colored output."
msgstr ""

#: ../../../doc/en/changelog.rst:579
msgid ""
"`#7467 <https://github.com/pytest-dev/pytest/issues/7467>`_: ``--log-file`` "
"CLI option and ``log_file`` ini marker now create subdirectories if needed."
msgstr ""

#: ../../../doc/en/changelog.rst:582
msgid ""
"`#7489 <https://github.com/pytest-dev/pytest/issues/7489>`_: The :func:"
"`pytest.raises` function has a clearer error message when ``match`` equals "
"the obtained string but is not a regex match. In this case it is suggested "
"to escape the regex."
msgstr ""

#: ../../../doc/en/changelog.rst:589
msgid ""
"`#7392 <https://github.com/pytest-dev/pytest/issues/7392>`_: Fix the "
"reported location of tests skipped with ``@pytest.mark.skip`` when ``--"
"runxfail`` is used."
msgstr ""

#: ../../../doc/en/changelog.rst:592
msgid ""
"`#7491 <https://github.com/pytest-dev/pytest/issues/7491>`_: :fixture:"
"`tmpdir` and :fixture:`tmp_path` no longer raise an error if the lock to "
"check for stale temporary directories is not accessible."
msgstr ""

#: ../../../doc/en/changelog.rst:596
msgid ""
"`#7517 <https://github.com/pytest-dev/pytest/issues/7517>`_: Preserve line "
"endings when captured via ``capfd``."
msgstr ""

#: ../../../doc/en/changelog.rst:599
msgid ""
"`#7534 <https://github.com/pytest-dev/pytest/issues/7534>`_: Restored the "
"previous formatting of ``TracebackEntry.__str__`` which was changed by "
"accident."
msgstr ""

#: ../../../doc/en/changelog.rst:606
msgid ""
"`#7422 <https://github.com/pytest-dev/pytest/issues/7422>`_: Clarified when "
"the ``usefixtures`` mark can apply fixtures to test."
msgstr ""

#: ../../../doc/en/changelog.rst:609
msgid ""
"`#7441 <https://github.com/pytest-dev/pytest/issues/7441>`_: Add a note "
"about ``-q`` option used in getting started guide."
msgstr ""

#: ../../../doc/en/changelog.rst:616
msgid ""
"`#7389 <https://github.com/pytest-dev/pytest/issues/7389>`_: Fixture scope "
"``package`` is no longer considered experimental."
msgstr ""

#: ../../../doc/en/changelog.rst:620
msgid "pytest 6.0.0rc1 (2020-07-08)"
msgstr ""

#: ../../../doc/en/changelog.rst:625
msgid ""
"`#1316 <https://github.com/pytest-dev/pytest/issues/1316>`_: ``TestReport."
"longrepr`` is now always an instance of ``ReprExceptionInfo``. Previously it "
"was a ``str`` when a test failed with ``pytest.fail(..., pytrace=False)``."
msgstr ""

#: ../../../doc/en/changelog.rst:628
msgid ""
"`#5965 <https://github.com/pytest-dev/pytest/issues/5965>`_: symlinks are no "
"longer resolved during collection and matching `conftest.py` files with test "
"file paths."
msgstr ""

#: ../../../doc/en/changelog.rst:630
msgid ""
"Resolving symlinks for the current directory and during collection was "
"introduced as a bugfix in 3.9.0, but it actually is a new feature which had "
"unfortunate consequences in Windows and surprising results in other "
"platforms."
msgstr ""

#: ../../../doc/en/changelog.rst:632
msgid ""
"The team decided to step back on resolving symlinks at all, planning to "
"review this in the future with a more solid solution (see discussion in "
"`#6523 <https://github.com/pytest-dev/pytest/pull/6523>`__ for details)."
msgstr ""

#: ../../../doc/en/changelog.rst:635
msgid ""
"This might break test suites which made use of this feature; the fix is to "
"create a symlink for the entire test tree, and not only to partial files/"
"tress as it was possible previously."
msgstr ""

#: ../../../doc/en/changelog.rst:639
msgid ""
"`#6505 <https://github.com/pytest-dev/pytest/issues/6505>`_: ``Testdir.run()."
"parseoutcomes()`` now always returns the parsed nouns in plural form."
msgstr ""

#: ../../../doc/en/changelog.rst:641
msgid ""
"Originally ``parseoutcomes()`` would always returns the nouns in plural "
"form, but a change meant to improve the terminal summary by using singular "
"form single items (``1 warning`` or ``1 error``) caused an unintended "
"regression by changing the keys returned by ``parseoutcomes()``."
msgstr ""

#: ../../../doc/en/changelog.rst:645
msgid ""
"Now the API guarantees to always return the plural form, so calls like this:"
msgstr ""

#: ../../../doc/en/changelog.rst:647
msgid ""
"result = testdir.runpytest()\n"
"result.assert_outcomes(error=1)"
msgstr ""

#: ../../../doc/en/changelog.rst:652
msgid "Need to be changed to:"
msgstr ""

#: ../../../doc/en/changelog.rst:655
msgid ""
"result = testdir.runpytest()\n"
"result.assert_outcomes(errors=1)"
msgstr ""

#: ../../../doc/en/changelog.rst:661
msgid ""
"`#6903 <https://github.com/pytest-dev/pytest/issues/6903>`_: The ``os."
"dup()`` function is now assumed to exist. We are not aware of any supported "
"Python 3 implementations which do not provide it."
msgstr ""

#: ../../../doc/en/changelog.rst:665
msgid ""
"`#7040 <https://github.com/pytest-dev/pytest/issues/7040>`_: ``-k`` no "
"longer matches against the names of the directories outside the test session "
"root."
msgstr ""

#: ../../../doc/en/changelog.rst:667
msgid ""
"Also, ``pytest.Package.name`` is now just the name of the directory "
"containing the package's ``__init__.py`` file, instead of the full path. "
"This is consistent with how the other nodes are named, and also one of the "
"reasons why ``-k`` would match against any directory containing the test "
"suite."
msgstr ""

#: ../../../doc/en/changelog.rst:673
msgid ""
"`#7122 <https://github.com/pytest-dev/pytest/issues/7122>`_: Expressions "
"given to the ``-m`` and ``-k`` options are no longer evaluated using "
"Python's :func:`eval`. The format supports ``or``, ``and``, ``not``, "
"parenthesis and general identifiers to match against. Python constants, "
"keywords or other operators are no longer evaluated differently."
msgstr ""

#: ../../../doc/en/changelog.rst:678
msgid ""
"`#7135 <https://github.com/pytest-dev/pytest/issues/7135>`_: Pytest now uses "
"its own ``TerminalWriter`` class instead of using the one from the ``py`` "
"library. Plugins generally access this class through ``TerminalReporter."
"writer``, ``TerminalReporter.write()`` (and similar methods), or ``_pytest."
"config.create_terminal_writer()``."
msgstr ""

#: ../../../doc/en/changelog.rst:682
msgid "The following breaking changes were made:"
msgstr ""

#: ../../../doc/en/changelog.rst:684
msgid ""
"Output (``write()`` method and others) no longer flush implicitly; the "
"flushing behavior of the underlying file is respected. To flush explicitly "
"(for example, if you want output to be shown before an end-of-line is "
"printed), use ``write(flush=True)`` or ``terminal_writer.flush()``."
msgstr ""

#: ../../../doc/en/changelog.rst:688
msgid ""
"Explicit Windows console support was removed, delegated to the colorama "
"library."
msgstr ""

#: ../../../doc/en/changelog.rst:689
msgid "Support for writing ``bytes`` was removed."
msgstr ""

#: ../../../doc/en/changelog.rst:690
msgid ""
"The ``reline`` method and ``chars_on_current_line`` property were removed."
msgstr ""

#: ../../../doc/en/changelog.rst:691
msgid "The ``stringio`` and ``encoding`` arguments was removed."
msgstr ""

#: ../../../doc/en/changelog.rst:692
msgid "Support for passing a callable instead of a file was removed."
msgstr ""

#: ../../../doc/en/changelog.rst:695
msgid ""
"`#7224 <https://github.com/pytest-dev/pytest/issues/7224>`_: The `item."
"catch_log_handler` and `item.catch_log_handlers` attributes, set by the "
"logging plugin and never meant to be public, are no longer available."
msgstr ""

#: ../../../doc/en/changelog.rst:698
msgid ""
"The deprecated ``--no-print-logs`` option and ``log_print`` ini option are "
"removed. Use ``--show-capture`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:701
msgid ""
"`#7226 <https://github.com/pytest-dev/pytest/issues/7226>`_: Removed the "
"unused ``args`` parameter from ``pytest.Function.__init__``."
msgstr ""

#: ../../../doc/en/changelog.rst:704
msgid ""
"`#7418 <https://github.com/pytest-dev/pytest/issues/7418>`_: Removed the "
"`pytest_doctest_prepare_content` hook specification. This hook hasn't been "
"triggered by pytest for at least 10 years."
msgstr ""

#: ../../../doc/en/changelog.rst:708
msgid ""
"`#7438 <https://github.com/pytest-dev/pytest/issues/7438>`_: Some changes "
"were made to the internal ``_pytest._code.source``, listed here for the "
"benefit of plugin authors who may be using it:"
msgstr ""

#: ../../../doc/en/changelog.rst:711
msgid ""
"The ``deindent`` argument to ``Source()`` has been removed, now it is always "
"true."
msgstr ""

#: ../../../doc/en/changelog.rst:712
msgid ""
"Support for zero or multiple arguments to ``Source()`` has been removed."
msgstr ""

#: ../../../doc/en/changelog.rst:713
msgid "Support for comparing ``Source`` with an ``str`` has been removed."
msgstr ""

#: ../../../doc/en/changelog.rst:714
msgid ""
"The methods ``Source.isparseable()`` and ``Source.putaround()`` have been "
"removed."
msgstr ""

#: ../../../doc/en/changelog.rst:715
msgid ""
"The method ``Source.compile()`` and function ``_pytest._code.compile()`` "
"have been removed; use plain ``compile()`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:717
msgid ""
"The function ``_pytest._code.source.getsource()`` has been removed; use "
"``Source()`` directly instead."
msgstr ""

#: ../../../doc/en/changelog.rst:731
msgid ""
"`#4049 <https://github.com/pytest-dev/pytest/issues/4049>`_: "
"``pytest_warning_captured`` is deprecated in favor of the "
"``pytest_warning_recorded`` hook."
msgstr ""

#: ../../../doc/en/changelog.rst:737
msgid ""
"`#1556 <https://github.com/pytest-dev/pytest/issues/1556>`_: pytest now "
"supports ``pyproject.toml`` files for configuration."
msgstr ""

#: ../../../doc/en/changelog.rst:739
msgid ""
"The configuration options is similar to the one available in other formats, "
"but must be defined in a ``[tool.pytest.ini_options]`` table to be picked up "
"by pytest:"
msgstr ""

#: ../../../doc/en/changelog.rst:742
msgid ""
"# pyproject.toml\n"
"[tool.pytest.ini_options]\n"
"minversion = \"6.0\"\n"
"addopts = \"-ra -q\"\n"
"testpaths = [\n"
"    \"tests\",\n"
"    \"integration\",\n"
"]"
msgstr ""

#: ../../../doc/en/changelog.rst:753
msgid ""
"More information can be found `in the docs <https://docs.pytest.org/en/"
"stable/customize.html#configuration-file-formats>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:756
msgid ""
"`#3342 <https://github.com/pytest-dev/pytest/issues/3342>`_: pytest now "
"includes inline type annotations and exposes them to user programs. Most of "
"the user-facing API is covered, as well as internal code."
msgstr ""

#: ../../../doc/en/changelog.rst:759
msgid ""
"If you are running a type checker such as mypy on your tests, you may start "
"noticing type errors indicating incorrect usage. If you run into an error "
"that you believe to be incorrect, please let us know in an issue."
msgstr ""

#: ../../../doc/en/changelog.rst:763
msgid ""
"The types were developed against mypy version 0.780. Versions before 0.750 "
"are known not to work. We recommend using the latest version. Other type "
"checkers may work as well, but they are not officially verified to work by "
"pytest yet."
msgstr ""

#: ../../../doc/en/changelog.rst:769
msgid ""
"`#4049 <https://github.com/pytest-dev/pytest/issues/4049>`_: Introduced a "
"new hook named `pytest_warning_recorded` to convey information about "
"warnings captured by the internal `pytest` warnings plugin."
msgstr ""

#: ../../../doc/en/changelog.rst:771
msgid ""
"This hook is meant to replace `pytest_warning_captured`, which is deprecated "
"and will be removed in a future release."
msgstr ""

#: ../../../doc/en/changelog.rst:774
msgid ""
"`#6471 <https://github.com/pytest-dev/pytest/issues/6471>`_: New command-"
"line flags:"
msgstr ""

#: ../../../doc/en/changelog.rst:776
msgid ""
"`--no-header`: disables the initial header, including platform, version, and "
"plugins."
msgstr ""

#: ../../../doc/en/changelog.rst:777
msgid "`--no-summary`: disables the final test summary, including warnings."
msgstr ""

#: ../../../doc/en/changelog.rst:780
msgid ""
"`#6856 <https://github.com/pytest-dev/pytest/issues/6856>`_: A warning is "
"now shown when an unknown key is read from a config INI file."
msgstr ""

#: ../../../doc/en/changelog.rst:782
msgid ""
"The `--strict-config` flag has been added to treat these warnings as errors."
msgstr ""

#: ../../../doc/en/changelog.rst:785
msgid ""
"`#6906 <https://github.com/pytest-dev/pytest/issues/6906>`_: Added `--code-"
"highlight` command line option to enable/disable code highlighting in "
"terminal output."
msgstr ""

#: ../../../doc/en/changelog.rst:788
msgid ""
"`#7245 <https://github.com/pytest-dev/pytest/issues/7245>`_: New ``--import-"
"mode=importlib`` option that uses `importlib <https://docs.python.org/3/"
"library/importlib.html>`__ to import test modules."
msgstr ""

#: ../../../doc/en/changelog.rst:790
msgid ""
"Traditionally pytest used ``__import__`` while changing ``sys.path`` to "
"import test modules (which also changes ``sys.modules`` as a side-effect), "
"which works but has a number of drawbacks, like requiring test modules that "
"don't live in packages to have unique names (as they need to reside under a "
"unique name in ``sys.modules``)."
msgstr ""

#: ../../../doc/en/changelog.rst:794
msgid ""
"``--import-mode=importlib`` uses more fine grained import mechanisms from "
"``importlib`` which don't require pytest to change ``sys.path`` or ``sys."
"modules`` at all, eliminating much of the drawbacks of the previous mode."
msgstr ""

#: ../../../doc/en/changelog.rst:798
msgid ""
"We intend to make ``--import-mode=importlib`` the default in future "
"versions, so users are encouraged to try the new mode and provide feedback "
"(both positive or negative) in issue `#7245 <https://github.com/pytest-dev/"
"pytest/issues/7245>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:801
msgid ""
"You can read more about this option in `the documentation <https://docs."
"pytest.org/en/latest/pythonpath.html#import-modes>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:804
msgid ""
"`#7305 <https://github.com/pytest-dev/pytest/issues/7305>`_: New "
"``required_plugins`` configuration option allows the user to specify a list "
"of plugins, including version information, that are required for pytest to "
"run. An error is raised if any required plugins are not found when running "
"pytest."
msgstr ""

#: ../../../doc/en/changelog.rst:810
msgid ""
"`#4375 <https://github.com/pytest-dev/pytest/issues/4375>`_: The ``pytest`` "
"command now suppresses the ``BrokenPipeError`` error message that is printed "
"to stderr when the output of ``pytest`` is piped and and the pipe is closed "
"by the piped-to program (common examples are ``less`` and ``head``)."
msgstr ""

#: ../../../doc/en/changelog.rst:815
msgid ""
"`#4391 <https://github.com/pytest-dev/pytest/issues/4391>`_: Improved "
"precision of test durations measurement. ``CallInfo`` items now have a new "
"``<CallInfo>.duration`` attribute, created using ``time.perf_counter()``. "
"This attribute is used to fill the ``<TestReport>.duration`` attribute, "
"which is more accurate than the previous ``<CallInfo>.stop - <CallInfo>."
"start`` (as these are based on ``time.time()``)."
msgstr ""

#: ../../../doc/en/changelog.rst:818
msgid ""
"`#4675 <https://github.com/pytest-dev/pytest/issues/4675>`_: Rich comparison "
"for dataclasses and `attrs`-classes is now recursive."
msgstr ""

#: ../../../doc/en/changelog.rst:821
msgid ""
"`#6285 <https://github.com/pytest-dev/pytest/issues/6285>`_: Exposed the "
"`pytest.FixtureLookupError` exception which is raised by `request."
"getfixturevalue()` (where `request` is a `FixtureRequest` fixture) when a "
"fixture with the given name cannot be returned."
msgstr ""

#: ../../../doc/en/changelog.rst:825
msgid ""
"`#6433 <https://github.com/pytest-dev/pytest/issues/6433>`_: If an error is "
"encountered while formatting the message in a logging call, for example "
"``logging.warning(\"oh no!: %s: %s\", \"first\")`` (a second argument is "
"missing), pytest now propagates the error, likely causing the test to fail."
msgstr ""

#: ../../../doc/en/changelog.rst:829
msgid ""
"Previously, such a mistake would cause an error to be printed to stderr, "
"which is not displayed by default for passing tests. This change makes the "
"mistake visible during testing."
msgstr ""

#: ../../../doc/en/changelog.rst:833
msgid ""
"You may supress this behavior temporarily or permanently by setting "
"``logging.raiseExceptions = False``."
msgstr ""

#: ../../../doc/en/changelog.rst:837
msgid ""
"`#6817 <https://github.com/pytest-dev/pytest/issues/6817>`_: Explicit new-"
"lines in help texts of command-line options are preserved, allowing plugins "
"better control of the help displayed to users."
msgstr ""

#: ../../../doc/en/changelog.rst:841
msgid ""
"`#6940 <https://github.com/pytest-dev/pytest/issues/6940>`_: When using the "
"``--duration`` option, the terminal message output is now more precise about "
"the number and duration of hidden items."
msgstr ""

#: ../../../doc/en/changelog.rst:844
msgid ""
"`#6991 <https://github.com/pytest-dev/pytest/issues/6991>`_: Collected files "
"are displayed after any reports from hooks, e.g. the status from ``--lf``."
msgstr ""

#: ../../../doc/en/changelog.rst:847
msgid ""
"`#7091 <https://github.com/pytest-dev/pytest/issues/7091>`_: When ``fd`` "
"capturing is used, through ``--capture=fd`` or the ``capfd`` and "
"``capfdbinary`` fixtures, and the file descriptor (0, 1, 2) cannot be "
"duplicated, FD capturing is still performed. Previously, direct writes to "
"the file descriptors would fail or be lost in this case."
msgstr ""

#: ../../../doc/en/changelog.rst:853
msgid ""
"`#7119 <https://github.com/pytest-dev/pytest/issues/7119>`_: Exit with an "
"error if the ``--basetemp`` argument is empty, is the current working "
"directory or is one of the parent directories. This is done to protect "
"against accidental data loss, as any directory passed to this argument is "
"cleared."
msgstr ""

#: ../../../doc/en/changelog.rst:857
msgid ""
"`#7128 <https://github.com/pytest-dev/pytest/issues/7128>`_: `pytest --"
"version` now displays just the pytest version, while `pytest --version --"
"version` displays more verbose information including plugins. This is more "
"consistent with how other tools show `--version`."
msgstr ""

#: ../../../doc/en/changelog.rst:860
msgid ""
"`#7133 <https://github.com/pytest-dev/pytest/issues/7133>`_: :meth:`caplog."
"set_level() <_pytest.logging.LogCaptureFixture.set_level>` will now override "
"any :confval:`log_level` set via the CLI or configuration file."
msgstr ""

#: ../../../doc/en/changelog.rst:863
msgid ""
"`#7159 <https://github.com/pytest-dev/pytest/issues/7159>`_: :meth:`caplog."
"set_level() <_pytest.logging.LogCaptureFixture.set_level>` and :meth:`caplog."
"at_level() <_pytest.logging.LogCaptureFixture.at_level>` no longer affect "
"the level of logs that are shown in the *Captured log report* report section."
msgstr ""

#: ../../../doc/en/changelog.rst:867
msgid ""
"`#7348 <https://github.com/pytest-dev/pytest/issues/7348>`_: Improve "
"recursive diff report for comparison asserts on dataclasses / attrs."
msgstr ""

#: ../../../doc/en/changelog.rst:870
msgid ""
"`#7385 <https://github.com/pytest-dev/pytest/issues/7385>`_: ``--junitxml`` "
"now includes the exception cause in the ``message`` XML attribute for "
"failures during setup and teardown."
msgstr ""

#: ../../../doc/en/changelog.rst:872
msgid "Previously:"
msgstr ""

#: ../../../doc/en/changelog.rst:874
msgid "<error message=\"test setup failure\">"
msgstr ""

#: ../../../doc/en/changelog.rst:878
msgid "Now:"
msgstr ""

#: ../../../doc/en/changelog.rst:880
msgid ""
"<error message=\"failed on setup with &quot;ValueError: Some error during "
"setup&quot;\">"
msgstr ""

#: ../../../doc/en/changelog.rst:889
msgid ""
"`#1120 <https://github.com/pytest-dev/pytest/issues/1120>`_: Fix issue where "
"directories from :fixture:`tmpdir` are not removed properly when multiple "
"instances of pytest are running in parallel."
msgstr ""

#: ../../../doc/en/changelog.rst:892
msgid ""
"`#4583 <https://github.com/pytest-dev/pytest/issues/4583>`_: Prevent "
"crashing and provide a user-friendly error when a marker expression (`-m`) "
"invoking of :func:`eval` raises any exception."
msgstr ""

#: ../../../doc/en/changelog.rst:895
msgid ""
"`#4677 <https://github.com/pytest-dev/pytest/issues/4677>`_: The path shown "
"in the summary report for SKIPPED tests is now always relative. Previously "
"it was sometimes absolute."
msgstr ""

#: ../../../doc/en/changelog.rst:898
msgid ""
"`#5456 <https://github.com/pytest-dev/pytest/issues/5456>`_: Fix a possible "
"race condition when trying to remove lock files used to control access to "
"folders created by :fixture:`tmp_path` and :fixture:`tmpdir`."
msgstr ""

#: ../../../doc/en/changelog.rst:902
msgid ""
"`#6240 <https://github.com/pytest-dev/pytest/issues/6240>`_: Fixes an issue "
"where logging during collection step caused duplication of log messages to "
"stderr."
msgstr ""

#: ../../../doc/en/changelog.rst:906 ../../../doc/en/changelog.rst:1027
msgid ""
"`#6428 <https://github.com/pytest-dev/pytest/issues/6428>`_: Paths appearing "
"in error messages are now correct in case the current working directory has "
"changed since the start of the session."
msgstr ""

#: ../../../doc/en/changelog.rst:910
msgid ""
"`#6755 <https://github.com/pytest-dev/pytest/issues/6755>`_: Support "
"deleting paths longer than 260 characters on windows created inside :fixture:"
"`tmpdir`."
msgstr ""

#: ../../../doc/en/changelog.rst:913
msgid ""
"`#6871 <https://github.com/pytest-dev/pytest/issues/6871>`_: Fix crash with "
"captured output when using :fixture:`capsysbinary`."
msgstr ""

#: ../../../doc/en/changelog.rst:916 ../../../doc/en/changelog.rst:1086
msgid ""
"`#6909 <https://github.com/pytest-dev/pytest/issues/6909>`_: Revert the "
"change introduced by `#6330 <https://github.com/pytest-dev/pytest/"
"pull/6330>`_, which required all arguments to ``@pytest.mark.parametrize`` "
"to be explicitly defined in the function signature."
msgstr ""

#: ../../../doc/en/changelog.rst:918 ../../../doc/en/changelog.rst:1088
msgid ""
"The intention of the original change was to remove what was expected to be "
"an unintended/surprising behavior, but it turns out many people relied on "
"it, so the restriction has been reverted."
msgstr ""

#: ../../../doc/en/changelog.rst:921 ../../../doc/en/changelog.rst:1091
msgid ""
"`#6910 <https://github.com/pytest-dev/pytest/issues/6910>`_: Fix crash when "
"plugins return an unknown stats while using the ``--reportlog`` option."
msgstr ""

#: ../../../doc/en/changelog.rst:924 ../../../doc/en/changelog.rst:1053
msgid ""
"`#6924 <https://github.com/pytest-dev/pytest/issues/6924>`_: Ensure a "
"``unittest.IsolatedAsyncioTestCase`` is actually awaited."
msgstr ""

#: ../../../doc/en/changelog.rst:927
msgid ""
"`#6925 <https://github.com/pytest-dev/pytest/issues/6925>`_: Fix "
"`TerminalRepr` instances to be hashable again."
msgstr ""

#: ../../../doc/en/changelog.rst:930
msgid ""
"`#6947 <https://github.com/pytest-dev/pytest/issues/6947>`_: Fix regression "
"where functions registered with :meth:`unittest.TestCase.addCleanup` were "
"not being called on test failures."
msgstr ""

#: ../../../doc/en/changelog.rst:933 ../../../doc/en/changelog.rst:1062
msgid ""
"`#6951 <https://github.com/pytest-dev/pytest/issues/6951>`_: Allow users to "
"still set the deprecated ``TerminalReporter.writer`` attribute."
msgstr ""

#: ../../../doc/en/changelog.rst:936
msgid ""
"`#6956 <https://github.com/pytest-dev/pytest/issues/6956>`_: Prevent pytest "
"from printing `ConftestImportFailure` traceback to stdout."
msgstr ""

#: ../../../doc/en/changelog.rst:939
msgid ""
"`#6991 <https://github.com/pytest-dev/pytest/issues/6991>`_: Fix regressions "
"with `--lf` filtering too much since pytest 5.4."
msgstr ""

#: ../../../doc/en/changelog.rst:942
msgid ""
"`#6992 <https://github.com/pytest-dev/pytest/issues/6992>`_: Revert "
"\"tmpdir: clean up indirection via config for factories\" `#6767 <https://"
"github.com/pytest-dev/pytest/issues/6767>`_ as it breaks pytest-xdist."
msgstr ""

#: ../../../doc/en/changelog.rst:945
msgid ""
"`#7061 <https://github.com/pytest-dev/pytest/issues/7061>`_: When a yielding "
"fixture fails to yield a value, report a test setup error instead of "
"crashing."
msgstr ""

#: ../../../doc/en/changelog.rst:948
msgid ""
"`#7076 <https://github.com/pytest-dev/pytest/issues/7076>`_: The path of "
"file skipped by ``@pytest.mark.skip`` in the SKIPPED report is now relative "
"to invocation directory. Previously it was relative to root directory."
msgstr ""

#: ../../../doc/en/changelog.rst:951 ../../../doc/en/changelog.rst:1068
msgid ""
"`#7110 <https://github.com/pytest-dev/pytest/issues/7110>`_: Fixed "
"regression: ``asyncbase.TestCase`` tests are executed correctly again."
msgstr ""

#: ../../../doc/en/changelog.rst:954
msgid ""
"`#7126 <https://github.com/pytest-dev/pytest/issues/7126>`_: ``--setup-"
"show`` now doesn't raise an error when a bytes value is used as a "
"``parametrize`` parameter when Python is called with the ``-bb`` flag."
msgstr ""

#: ../../../doc/en/changelog.rst:958
msgid ""
"`#7143 <https://github.com/pytest-dev/pytest/issues/7143>`_: Fix :meth:"
"`pytest.File.from_parent` so it forwards extra keyword arguments to the "
"constructor."
msgstr ""

#: ../../../doc/en/changelog.rst:961 ../../../doc/en/changelog.rst:1074
msgid ""
"`#7145 <https://github.com/pytest-dev/pytest/issues/7145>`_: Classes with "
"broken ``__getattribute__`` methods are displayed correctly during failures."
msgstr ""

#: ../../../doc/en/changelog.rst:964 ../../../doc/en/changelog.rst:1037
msgid ""
"`#7150 <https://github.com/pytest-dev/pytest/issues/7150>`_: Prevent hiding "
"the underlying exception when ``ConfTestImportFailure`` is raised."
msgstr ""

#: ../../../doc/en/changelog.rst:967 ../../../doc/en/changelog.rst:1077
msgid ""
"`#7180 <https://github.com/pytest-dev/pytest/issues/7180>`_: Fix "
"``_is_setup_py`` for files encoded differently than locale."
msgstr ""

#: ../../../doc/en/changelog.rst:970
msgid ""
"`#7215 <https://github.com/pytest-dev/pytest/issues/7215>`_: Fix regression "
"where running with ``--pdb`` would call :meth:`unittest.TestCase.tearDown` "
"for skipped tests."
msgstr ""

#: ../../../doc/en/changelog.rst:973
msgid ""
"`#7253 <https://github.com/pytest-dev/pytest/issues/7253>`_: When using "
"``pytest.fixture`` on a function directly, as in ``pytest.fixture(func)``, "
"if the ``autouse`` or ``params`` arguments are also passed, the function is "
"no longer ignored, but is marked as a fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:978
msgid ""
"`#7360 <https://github.com/pytest-dev/pytest/issues/7360>`_: Fix possibly "
"incorrect evaluation of string expressions passed to ``pytest.mark.skipif`` "
"and ``pytest.mark.xfail``, in rare circumstances where the exact same string "
"is used but refers to different global values."
msgstr ""

#: ../../../doc/en/changelog.rst:982
msgid ""
"`#7383 <https://github.com/pytest-dev/pytest/issues/7383>`_: Fixed exception "
"causes all over the codebase, i.e. use `raise new_exception from "
"old_exception` when wrapping an exception."
msgstr ""

#: ../../../doc/en/changelog.rst:989
msgid ""
"`#7202 <https://github.com/pytest-dev/pytest/issues/7202>`_: The development "
"guide now links to the contributing section of the docs and `RELEASING.rst` "
"on GitHub."
msgstr ""

#: ../../../doc/en/changelog.rst:992
msgid ""
"`#7233 <https://github.com/pytest-dev/pytest/issues/7233>`_: Add a note "
"about ``--strict`` and ``--strict-markers`` and the preference for the "
"latter one."
msgstr ""

#: ../../../doc/en/changelog.rst:995
msgid ""
"`#7345 <https://github.com/pytest-dev/pytest/issues/7345>`_: Explain "
"indirect parametrization and markers for fixtures."
msgstr ""

#: ../../../doc/en/changelog.rst:1002
msgid ""
"`#7035 <https://github.com/pytest-dev/pytest/issues/7035>`_: The "
"``originalname`` attribute of ``_pytest.python.Function`` now defaults to "
"``name`` if not provided explicitly, and is always set."
msgstr ""

#: ../../../doc/en/changelog.rst:1006
msgid ""
"`#7264 <https://github.com/pytest-dev/pytest/issues/7264>`_: The dependency "
"on the ``wcwidth`` package has been removed."
msgstr ""

#: ../../../doc/en/changelog.rst:1009
msgid ""
"`#7291 <https://github.com/pytest-dev/pytest/issues/7291>`_: Replaced ``py."
"iniconfig`` with `iniconfig <https://pypi.org/project/iniconfig/>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:1012
msgid ""
"`#7295 <https://github.com/pytest-dev/pytest/issues/7295>`_: ``src/_pytest/"
"config/__init__.py`` now uses the ``warnings`` module to report warnings "
"instead of ``sys.stderr.write``."
msgstr ""

#: ../../../doc/en/changelog.rst:1015
msgid ""
"`#7356 <https://github.com/pytest-dev/pytest/issues/7356>`_: Remove last "
"internal uses of deprecated *slave* term from old ``pytest-xdist``."
msgstr ""

#: ../../../doc/en/changelog.rst:1018
msgid ""
"`#7357 <https://github.com/pytest-dev/pytest/issues/7357>`_: ``py``>=1.8.2 "
"is now required."
msgstr ""

#: ../../../doc/en/changelog.rst:1022
msgid "pytest 5.4.3 (2020-06-02)"
msgstr ""

#: ../../../doc/en/changelog.rst:1031
msgid ""
"`#6755 <https://github.com/pytest-dev/pytest/issues/6755>`_: Support "
"deleting paths longer than 260 characters on windows created inside tmpdir."
msgstr ""

#: ../../../doc/en/changelog.rst:1034
msgid ""
"`#6956 <https://github.com/pytest-dev/pytest/issues/6956>`_: Prevent pytest "
"from printing ConftestImportFailure traceback to stdout."
msgstr ""

#: ../../../doc/en/changelog.rst:1040
msgid ""
"`#7215 <https://github.com/pytest-dev/pytest/issues/7215>`_: Fix regression "
"where running with ``--pdb`` would call the ``tearDown`` methods of "
"``unittest.TestCase`` subclasses for skipped tests."
msgstr ""

#: ../../../doc/en/changelog.rst:1045
msgid "pytest 5.4.2 (2020-05-08)"
msgstr ""

#: ../../../doc/en/changelog.rst:1050
msgid ""
"`#6871 <https://github.com/pytest-dev/pytest/issues/6871>`_: Fix crash with "
"captured output when using the :fixture:`capsysbinary fixture "
"<capsysbinary>`."
msgstr ""

#: ../../../doc/en/changelog.rst:1056
msgid ""
"`#6925 <https://github.com/pytest-dev/pytest/issues/6925>`_: Fix "
"TerminalRepr instances to be hashable again."
msgstr ""

#: ../../../doc/en/changelog.rst:1059
msgid ""
"`#6947 <https://github.com/pytest-dev/pytest/issues/6947>`_: Fix regression "
"where functions registered with ``TestCase.addCleanup`` were not being "
"called on test failures."
msgstr ""

#: ../../../doc/en/changelog.rst:1065
msgid ""
"`#6992 <https://github.com/pytest-dev/pytest/issues/6992>`_: Revert "
"\"tmpdir: clean up indirection via config for factories\" #6767 as it breaks "
"pytest-xdist."
msgstr ""

#: ../../../doc/en/changelog.rst:1071
msgid ""
"`#7143 <https://github.com/pytest-dev/pytest/issues/7143>`_: Fix ``File."
"from_constructor`` so it forwards extra keyword arguments to the constructor."
msgstr ""

#: ../../../doc/en/changelog.rst:1081
msgid "pytest 5.4.1 (2020-03-13)"
msgstr ""

#: ../../../doc/en/changelog.rst:1095
msgid "pytest 5.4.0 (2020-03-12)"
msgstr ""

#: ../../../doc/en/changelog.rst:1100
msgid ""
"`#6316 <https://github.com/pytest-dev/pytest/issues/6316>`_: Matching of ``-"
"k EXPRESSION`` to test names is now case-insensitive."
msgstr ""

#: ../../../doc/en/changelog.rst:1103
msgid ""
"`#6443 <https://github.com/pytest-dev/pytest/issues/6443>`_: Plugins "
"specified with ``-p`` are now loaded after internal plugins, which results "
"in their hooks being called *before* the internal ones."
msgstr ""

#: ../../../doc/en/changelog.rst:1105
msgid "This makes the ``-p`` behavior consistent with ``PYTEST_PLUGINS``."
msgstr ""

#: ../../../doc/en/changelog.rst:1108
msgid ""
"`#6637 <https://github.com/pytest-dev/pytest/issues/6637>`_: Removed the "
"long-deprecated ``pytest_itemstart`` hook."
msgstr ""

#: ../../../doc/en/changelog.rst:1110
msgid ""
"This hook has been marked as deprecated and not been even called by pytest "
"for over 10 years now."
msgstr ""

#: ../../../doc/en/changelog.rst:1113
msgid ""
"`#6673 <https://github.com/pytest-dev/pytest/issues/6673>`_: Reversed / fix "
"meaning of \"+/-\" in error diffs.  \"-\" means that sth. expected is "
"missing in the result and \"+\" means that there are unexpected extras in "
"the result."
msgstr ""

#: ../../../doc/en/changelog.rst:1116
msgid ""
"`#6737 <https://github.com/pytest-dev/pytest/issues/6737>`_: The "
"``cached_result`` attribute of ``FixtureDef`` is now set to ``None`` when "
"the result is unavailable, instead of being deleted."
msgstr ""

#: ../../../doc/en/changelog.rst:1119
msgid ""
"If your plugin performs checks like ``hasattr(fixturedef, "
"'cached_result')``, for example in a ``pytest_fixture_post_finalizer`` hook "
"implementation, replace it with ``fixturedef.cached_result is not None``. If "
"you ``del`` the attribute, set it to ``None`` instead."
msgstr ""

#: ../../../doc/en/changelog.rst:1129
msgid ""
"`#3238 <https://github.com/pytest-dev/pytest/issues/3238>`_: Option ``--no-"
"print-logs`` is deprecated and meant to be removed in a future release. If "
"you use ``--no-print-logs``, please try out ``--show-capture`` and provide "
"feedback."
msgstr ""

#: ../../../doc/en/changelog.rst:1132
msgid ""
"``--show-capture`` command-line option was added in ``pytest 3.5.0`` and "
"allows to specify how to display captured output when tests fail: ``no``, "
"``stdout``, ``stderr``, ``log`` or ``all`` (the default)."
msgstr ""

#: ../../../doc/en/changelog.rst:1136
msgid ""
"`#571 <https://github.com/pytest-dev/pytest/issues/571>`_: Deprecate the "
"unused/broken `pytest_collect_directory` hook. It was misaligned since the "
"removal of the ``Directory`` collector in 2010 and incorrect/unusable as "
"soon as collection was split from test execution."
msgstr ""

#: ../../../doc/en/changelog.rst:1141
msgid ""
"`#5975 <https://github.com/pytest-dev/pytest/issues/5975>`_: Deprecate using "
"direct constructors for ``Nodes``."
msgstr ""

#: ../../../doc/en/changelog.rst:1143
msgid "Instead they are now constructed via ``Node.from_parent``."
msgstr ""

#: ../../../doc/en/changelog.rst:1145
msgid ""
"This transitional mechanism enables us to untangle the very intensely "
"entangled ``Node`` relationships by enforcing more controlled creation/"
"configuration patterns."
msgstr ""

#: ../../../doc/en/changelog.rst:1148
msgid ""
"As part of this change, session/config are already disallowed parameters and "
"as we work on the details we might need disallow a few more as well."
msgstr ""

#: ../../../doc/en/changelog.rst:1150
msgid ""
"Subclasses are expected to use `super().from_parent` if they intend to "
"expand the creation of `Nodes`."
msgstr ""

#: ../../../doc/en/changelog.rst:1153
msgid ""
"`#6779 <https://github.com/pytest-dev/pytest/issues/6779>`_: The "
"``TerminalReporter.writer`` attribute has been deprecated and should no "
"longer be used. This was inadvertently exposed as part of the public API of "
"that plugin and ties it too much with ``py.io.TerminalWriter``."
msgstr ""

#: ../../../doc/en/changelog.rst:1162
msgid ""
"`#4597 <https://github.com/pytest-dev/pytest/issues/4597>`_: New :ref:`--"
"capture=tee-sys <capture-method>` option to allow both live printing and "
"capturing of test output."
msgstr ""

#: ../../../doc/en/changelog.rst:1165
msgid ""
"`#5712 <https://github.com/pytest-dev/pytest/issues/5712>`_: Now all "
"arguments to ``@pytest.mark.parametrize`` need to be explicitly declared in "
"the function signature or via ``indirect``. Previously it was possible to "
"omit an argument if a fixture with the same name existed, which was just an "
"accident of implementation and was not meant to be a part of the API."
msgstr ""

#: ../../../doc/en/changelog.rst:1169
msgid ""
"`#6454 <https://github.com/pytest-dev/pytest/issues/6454>`_: Changed default "
"for `-r` to `fE`, which displays failures and errors in the :ref:`short test "
"summary <pytest.detailed_failed_tests_usage>`.  `-rN` can be used to disable "
"it (the old behavior)."
msgstr ""

#: ../../../doc/en/changelog.rst:1172
msgid ""
"`#6469 <https://github.com/pytest-dev/pytest/issues/6469>`_: New options "
"have been added to the :confval:`junit_logging` option: ``log``, ``out-"
"err``, and ``all``."
msgstr ""

#: ../../../doc/en/changelog.rst:1175
msgid ""
"`#6834 <https://github.com/pytest-dev/pytest/issues/6834>`_: Excess warning "
"summaries are now collapsed per file to ensure readable display of warning "
"summaries."
msgstr ""

#: ../../../doc/en/changelog.rst:1182
msgid ""
"`#1857 <https://github.com/pytest-dev/pytest/issues/1857>`_: ``pytest.mark."
"parametrize`` accepts integers for ``ids`` again, converting it to strings."
msgstr ""

#: ../../../doc/en/changelog.rst:1185
msgid ""
"`#449 <https://github.com/pytest-dev/pytest/issues/449>`_: Use \"yellow\" "
"main color with any XPASSED tests."
msgstr ""

#: ../../../doc/en/changelog.rst:1188 ../../../doc/en/changelog.rst:1364
msgid ""
"`#4639 <https://github.com/pytest-dev/pytest/issues/4639>`_: Revert \"A "
"warning is now issued when assertions are made for ``None``\"."
msgstr ""

#: ../../../doc/en/changelog.rst:1190 ../../../doc/en/changelog.rst:1366
msgid ""
"The warning proved to be less useful than initially expected and had quite a "
"few false positive cases."
msgstr ""

#: ../../../doc/en/changelog.rst:1194
msgid ""
"`#5686 <https://github.com/pytest-dev/pytest/issues/5686>`_: "
"``tmpdir_factory.mktemp`` now fails when given absolute and non-normalized "
"paths."
msgstr ""

#: ../../../doc/en/changelog.rst:1197
msgid ""
"`#5984 <https://github.com/pytest-dev/pytest/issues/5984>`_: The "
"``pytest_warning_captured`` hook now receives a ``location`` parameter with "
"the code location that generated the warning."
msgstr ""

#: ../../../doc/en/changelog.rst:1200
msgid ""
"`#6213 <https://github.com/pytest-dev/pytest/issues/6213>`_: pytester: the "
"``testdir`` fixture respects environment settings from the ``monkeypatch`` "
"fixture for inner runs."
msgstr ""

#: ../../../doc/en/changelog.rst:1203
msgid ""
"`#6247 <https://github.com/pytest-dev/pytest/issues/6247>`_: ``--fulltrace`` "
"is honored with collection errors."
msgstr ""

#: ../../../doc/en/changelog.rst:1206
msgid ""
"`#6384 <https://github.com/pytest-dev/pytest/issues/6384>`_: Make `--"
"showlocals` work also with `--tb=short`."
msgstr ""

#: ../../../doc/en/changelog.rst:1209
msgid ""
"`#6653 <https://github.com/pytest-dev/pytest/issues/6653>`_: Add support for "
"matching lines consecutively with :attr:`LineMatcher <_pytest.pytester."
"LineMatcher>`'s :func:`~_pytest.pytester.LineMatcher.fnmatch_lines` and :"
"func:`~_pytest.pytester.LineMatcher.re_match_lines`."
msgstr ""

#: ../../../doc/en/changelog.rst:1212
msgid ""
"`#6658 <https://github.com/pytest-dev/pytest/issues/6658>`_: Code is now "
"highlighted in tracebacks when ``pygments`` is installed."
msgstr ""

#: ../../../doc/en/changelog.rst:1214
msgid ""
"Users are encouraged to install ``pygments`` into their environment and "
"provide feedback, because the plan is to make ``pygments`` a regular "
"dependency in the future."
msgstr ""

#: ../../../doc/en/changelog.rst:1218
msgid ""
"`#6795 <https://github.com/pytest-dev/pytest/issues/6795>`_: Import usage "
"error message with invalid `-o` option."
msgstr ""

#: ../../../doc/en/changelog.rst:1221
msgid ""
"`#759 <https://github.com/pytest-dev/pytest/issues/759>`_: ``pytest.mark."
"parametrize`` supports iterators and generators for ``ids``."
msgstr ""

#: ../../../doc/en/changelog.rst:1228
msgid ""
"`#310 <https://github.com/pytest-dev/pytest/issues/310>`_: Add support for "
"calling `pytest.xfail()` and `pytest.importorskip()` with doctests."
msgstr ""

#: ../../../doc/en/changelog.rst:1231
msgid ""
"`#3823 <https://github.com/pytest-dev/pytest/issues/3823>`_: ``--trace`` now "
"works with unittests."
msgstr ""

#: ../../../doc/en/changelog.rst:1234
msgid ""
"`#4445 <https://github.com/pytest-dev/pytest/issues/4445>`_: Fixed some "
"warning reports produced by pytest to point to the correct location of the "
"warning in the user's code."
msgstr ""

#: ../../../doc/en/changelog.rst:1237
msgid ""
"`#5301 <https://github.com/pytest-dev/pytest/issues/5301>`_: Fix ``--last-"
"failed`` to collect new tests from files with known failures."
msgstr ""

#: ../../../doc/en/changelog.rst:1240
msgid ""
"`#5928 <https://github.com/pytest-dev/pytest/issues/5928>`_: Report "
"``PytestUnknownMarkWarning`` at the level of the user's code, not "
"``pytest``'s."
msgstr ""

#: ../../../doc/en/changelog.rst:1243
msgid ""
"`#5991 <https://github.com/pytest-dev/pytest/issues/5991>`_: Fix interaction "
"with ``--pdb`` and unittests: do not use unittest's ``TestCase.debug()``."
msgstr ""

#: ../../../doc/en/changelog.rst:1246 ../../../doc/en/changelog.rst:2153
msgid ""
"`#6334 <https://github.com/pytest-dev/pytest/issues/6334>`_: Fix summary "
"entries appearing twice when ``f/F`` and ``s/S`` report chars were used at "
"the same time in the ``-r`` command-line option (for example ``-rFf``)."
msgstr ""

#: ../../../doc/en/changelog.rst:1248 ../../../doc/en/changelog.rst:2155
msgid ""
"The upper case variants were never documented and the preferred form should "
"be the lower case."
msgstr ""

#: ../../../doc/en/changelog.rst:1251
msgid ""
"`#6409 <https://github.com/pytest-dev/pytest/issues/6409>`_: Fallback to "
"green (instead of yellow) for non-last items without previous passes with "
"colored terminal progress indicator."
msgstr ""

#: ../../../doc/en/changelog.rst:1254
msgid ""
"`#6454 <https://github.com/pytest-dev/pytest/issues/6454>`_: `--disable-"
"warnings` is honored with `-ra` and `-rA`."
msgstr ""

#: ../../../doc/en/changelog.rst:1257
msgid ""
"`#6497 <https://github.com/pytest-dev/pytest/issues/6497>`_: Fix bug in the "
"comparison of request key with cached key in fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:1259
msgid ""
"A construct ``if key == cached_key:`` can fail either because ``==`` is "
"explicitly disallowed, or for, e.g., NumPy arrays, where the result of ``a "
"== b`` cannot generally be converted to `bool`. The implemented fix replaces "
"`==` with ``is``."
msgstr ""

#: ../../../doc/en/changelog.rst:1263
msgid ""
"`#6557 <https://github.com/pytest-dev/pytest/issues/6557>`_: Make capture "
"output streams ``.write()`` method return the same return value from "
"original streams."
msgstr ""

#: ../../../doc/en/changelog.rst:1266
msgid ""
"`#6566 <https://github.com/pytest-dev/pytest/issues/6566>`_: Fix "
"``EncodedFile.writelines`` to call the underlying buffer's ``writelines`` "
"method."
msgstr ""

#: ../../../doc/en/changelog.rst:1269
msgid ""
"`#6575 <https://github.com/pytest-dev/pytest/issues/6575>`_: Fix internal "
"crash when ``faulthandler`` starts initialized (for example with "
"``PYTHONFAULTHANDLER=1`` environment variable set) and "
"``faulthandler_timeout`` defined in the configuration file."
msgstr ""

#: ../../../doc/en/changelog.rst:1274
msgid ""
"`#6597 <https://github.com/pytest-dev/pytest/issues/6597>`_: Fix node ids "
"which contain a parametrized empty-string variable."
msgstr ""

#: ../../../doc/en/changelog.rst:1277
msgid ""
"`#6646 <https://github.com/pytest-dev/pytest/issues/6646>`_: Assertion "
"rewriting hooks are (re)stored for the current item, which fixes them being "
"still used after e.g. pytester's :func:`testdir.runpytest <_pytest.pytester."
"Testdir.runpytest>` etc."
msgstr ""

#: ../../../doc/en/changelog.rst:1280
msgid ""
"`#6660 <https://github.com/pytest-dev/pytest/issues/6660>`_: :py:func:"
"`pytest.exit` is handled when emitted from the :func:`pytest_sessionfinish "
"<_pytest.hookspec.pytest_sessionfinish>` hook.  This includes quitting from "
"a debugger."
msgstr ""

#: ../../../doc/en/changelog.rst:1283
msgid ""
"`#6752 <https://github.com/pytest-dev/pytest/issues/6752>`_: When :py:func:"
"`pytest.raises` is used as a function (as opposed to a context manager), a "
"`match` keyword argument is now passed through to the tested function. "
"Previously it was swallowed and ignored (regression in pytest 5.1.0)."
msgstr ""

#: ../../../doc/en/changelog.rst:1288
msgid ""
"`#6801 <https://github.com/pytest-dev/pytest/issues/6801>`_: Do not display "
"empty lines inbetween traceback for unexpected exceptions with doctests."
msgstr ""

#: ../../../doc/en/changelog.rst:1291
msgid ""
"`#6802 <https://github.com/pytest-dev/pytest/issues/6802>`_: The :fixture:"
"`testdir fixture <testdir>` works within doctests now."
msgstr ""

#: ../../../doc/en/changelog.rst:1298
msgid ""
"`#6696 <https://github.com/pytest-dev/pytest/issues/6696>`_: Add list of "
"fixtures to start of fixture chapter."
msgstr ""

#: ../../../doc/en/changelog.rst:1301
msgid ""
"`#6742 <https://github.com/pytest-dev/pytest/issues/6742>`_: Expand first "
"sentence on fixtures into a paragraph."
msgstr ""

#: ../../../doc/en/changelog.rst:1308 ../../../doc/en/changelog.rst:2182
msgid ""
"`#6404 <https://github.com/pytest-dev/pytest/issues/6404>`_: Remove usage of "
"``parser`` module, deprecated in Python 3.9."
msgstr ""

#: ../../../doc/en/changelog.rst:1312
msgid "pytest 5.3.5 (2020-01-29)"
msgstr ""

#: ../../../doc/en/changelog.rst:1317
msgid ""
"`#6517 <https://github.com/pytest-dev/pytest/issues/6517>`_: Fix regression "
"in pytest 5.3.4 causing an INTERNALERROR due to a wrong assertion."
msgstr ""

#: ../../../doc/en/changelog.rst:1321
msgid "pytest 5.3.4 (2020-01-20)"
msgstr ""

#: ../../../doc/en/changelog.rst:1326
msgid ""
"`#6496 <https://github.com/pytest-dev/pytest/issues/6496>`_: Revert `#6436 "
"<https://github.com/pytest-dev/pytest/issues/6436>`__: unfortunately this "
"change has caused a number of regressions in many suites, so the team "
"decided to revert this change and make a new release while we continue to "
"look for a solution."
msgstr ""

#: ../../../doc/en/changelog.rst:1331
msgid "pytest 5.3.3 (2020-01-16)"
msgstr ""

#: ../../../doc/en/changelog.rst:1336
msgid ""
"`#2780 <https://github.com/pytest-dev/pytest/issues/2780>`_: Captured output "
"during teardown is shown with ``-rP``."
msgstr ""

#: ../../../doc/en/changelog.rst:1339
msgid ""
"`#5971 <https://github.com/pytest-dev/pytest/issues/5971>`_: Fix a ``pytest-"
"xdist`` crash when dealing with exceptions raised in subprocesses created by "
"the ``multiprocessing`` module."
msgstr ""

#: ../../../doc/en/changelog.rst:1343
msgid ""
"`#6436 <https://github.com/pytest-dev/pytest/issues/6436>`_: :class:"
"`FixtureDef <_pytest.fixtures.FixtureDef>` objects now properly register "
"their finalizers with autouse and parameterized fixtures that execute before "
"them in the fixture stack so they are torn down at the right times, and in "
"the right order."
msgstr ""

#: ../../../doc/en/changelog.rst:1348
msgid ""
"`#6532 <https://github.com/pytest-dev/pytest/issues/6532>`_: Fix parsing of "
"outcomes containing multiple errors with ``testdir`` results (regression in "
"5.3.0)."
msgstr ""

#: ../../../doc/en/changelog.rst:1355
msgid ""
"`#6350 <https://github.com/pytest-dev/pytest/issues/6350>`_: Optimized "
"automatic renaming of test parameter IDs."
msgstr ""

#: ../../../doc/en/changelog.rst:1359
msgid "pytest 5.3.2 (2019-12-13)"
msgstr ""

#: ../../../doc/en/changelog.rst:1374 ../../../doc/en/changelog.rst:2207
msgid ""
"`#5430 <https://github.com/pytest-dev/pytest/issues/5430>`_: junitxml: Logs "
"for failed test are now passed to junit report in case the test fails during "
"call phase."
msgstr ""

#: ../../../doc/en/changelog.rst:1377
msgid ""
"`#6290 <https://github.com/pytest-dev/pytest/issues/6290>`_: The supporting "
"files in the ``.pytest_cache`` directory are kept with ``--cache-clear``, "
"which only clears cached values now."
msgstr ""

#: ../../../doc/en/changelog.rst:1380 ../../../doc/en/changelog.rst:2191
msgid ""
"`#6301 <https://github.com/pytest-dev/pytest/issues/6301>`_: Fix assertion "
"rewriting for egg-based distributions and ``editable`` installs (``pip "
"install --editable``)."
msgstr ""

#: ../../../doc/en/changelog.rst:1384
msgid "pytest 5.3.1 (2019-11-25)"
msgstr ""

#: ../../../doc/en/changelog.rst:1389
msgid ""
"`#6231 <https://github.com/pytest-dev/pytest/issues/6231>`_: Improve check "
"for misspelling of :ref:`pytest.mark.parametrize ref`."
msgstr ""

#: ../../../doc/en/changelog.rst:1392
msgid ""
"`#6257 <https://github.com/pytest-dev/pytest/issues/6257>`_: Handle :py:func:"
"`pytest.exit` being used via :py:func:`~_pytest.hookspec."
"pytest_internalerror`, e.g. when quitting pdb from post mortem."
msgstr ""

#: ../../../doc/en/changelog.rst:1399
msgid ""
"`#5914 <https://github.com/pytest-dev/pytest/issues/5914>`_: pytester: fix :"
"py:func:`~_pytest.pytester.LineMatcher.no_fnmatch_line` when used after "
"positive matching."
msgstr ""

#: ../../../doc/en/changelog.rst:1402
msgid ""
"`#6082 <https://github.com/pytest-dev/pytest/issues/6082>`_: Fix line "
"detection for doctest samples inside :py:class:`python:property` docstrings, "
"as a workaround to `bpo-17446 <https://bugs.python.org/issue17446>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:1405
msgid ""
"`#6254 <https://github.com/pytest-dev/pytest/issues/6254>`_: Fix "
"compatibility with pytest-parallel (regression in pytest 5.3.0)."
msgstr ""

#: ../../../doc/en/changelog.rst:1408
msgid ""
"`#6255 <https://github.com/pytest-dev/pytest/issues/6255>`_: Clear the :py:"
"data:`sys.last_traceback`, :py:data:`sys.last_type` and :py:data:`sys."
"last_value` attributes by deleting them instead of setting them to ``None``. "
"This better matches the behaviour of the Python standard library."
msgstr ""

#: ../../../doc/en/changelog.rst:1415
msgid "pytest 5.3.0 (2019-11-19)"
msgstr ""

#: ../../../doc/en/changelog.rst:1420
msgid ""
"`#6179 <https://github.com/pytest-dev/pytest/issues/6179>`_: The default "
"value of :confval:`junit_family` option will change to ``\"xunit2\"`` in "
"pytest 6.0, given that this is the version supported by default in modern "
"tools that manipulate this type of file."
msgstr ""

#: ../../../doc/en/changelog.rst:1423
msgid ""
"In order to smooth the transition, pytest will issue a warning in case the "
"``--junitxml`` option is given in the command line but :confval:"
"`junit_family` is not explicitly configured in ``pytest.ini``."
msgstr ""

#: ../../../doc/en/changelog.rst:1426
msgid ""
"For more information, `see the docs <https://docs.pytest.org/en/stable/"
"deprecations.html#junit-family-default-value-change-to-xunit2>`__."
msgstr ""

#: ../../../doc/en/changelog.rst:1433
msgid ""
"`#4488 <https://github.com/pytest-dev/pytest/issues/4488>`_: The pytest team "
"has created the `pytest-reportlog <https://github.com/pytest-dev/pytest-"
"reportlog>`__ plugin, which provides a new ``--report-log=FILE`` option that "
"writes *report logs* into a file as the test session executes."
msgstr ""

#: ../../../doc/en/changelog.rst:1436
msgid ""
"Each line of the report log contains a self contained JSON object "
"corresponding to a testing event, such as a collection or a test result "
"report. The file is guaranteed to be flushed after writing each line, so "
"systems can read and process events in real-time."
msgstr ""

#: ../../../doc/en/changelog.rst:1440
msgid ""
"The plugin is meant to replace the ``--resultlog`` option, which is "
"deprecated and meant to be removed in a future release. If you use ``--"
"resultlog``, please try out ``pytest-reportlog`` and provide feedback."
msgstr ""

#: ../../../doc/en/changelog.rst:1445
msgid ""
"`#4730 <https://github.com/pytest-dev/pytest/issues/4730>`_: When :py:data:"
"`sys.pycache_prefix` (Python 3.8+) is set, it will be used by pytest to "
"cache test files changed by the assertion rewriting mechanism."
msgstr ""

#: ../../../doc/en/changelog.rst:1447
msgid ""
"This makes it easier to benefit of cached ``.pyc`` files even on file "
"systems without permissions."
msgstr ""

#: ../../../doc/en/changelog.rst:1450
msgid ""
"`#5515 <https://github.com/pytest-dev/pytest/issues/5515>`_: Allow selective "
"auto-indentation of multiline log messages."
msgstr ""

#: ../../../doc/en/changelog.rst:1452
msgid ""
"Adds command line option ``--log-auto-indent``, config option :confval:"
"`log_auto_indent` and support for per-entry configuration of indentation "
"behavior on calls to :py:func:`python:logging.log()`."
msgstr ""

#: ../../../doc/en/changelog.rst:1456
msgid ""
"Alters the default for auto-indention from ``\"on\"`` to ``\"off\"``. This "
"restores the older behavior that existed prior to v4.6.0. This reversion to "
"earlier behavior was done because it is better to activate new features that "
"may lead to broken tests explicitly rather than implicitly."
msgstr ""

#: ../../../doc/en/changelog.rst:1463
msgid ""
"`#5914 <https://github.com/pytest-dev/pytest/issues/5914>`_: :fixture:"
"`testdir` learned two new functions, :py:func:`~_pytest.pytester.LineMatcher."
"no_fnmatch_line` and :py:func:`~_pytest.pytester.LineMatcher."
"no_re_match_line`."
msgstr ""

#: ../../../doc/en/changelog.rst:1466
msgid ""
"The functions are used to ensure the captured text *does not* match the "
"given pattern."
msgstr ""

#: ../../../doc/en/changelog.rst:1469
msgid "The previous idiom was to use :py:func:`python:re.match`:"
msgstr ""

#: ../../../doc/en/changelog.rst:1471
msgid ""
"result = testdir.runpytest()\n"
"assert re.match(pat, result.stdout.str()) is None"
msgstr ""

#: ../../../doc/en/changelog.rst:1476
msgid "Or the ``in`` operator:"
msgstr ""

#: ../../../doc/en/changelog.rst:1478
msgid ""
"result = testdir.runpytest()\n"
"assert text in result.stdout.str()"
msgstr ""

#: ../../../doc/en/changelog.rst:1483
msgid "But the new functions produce best output on failure."
msgstr ""

#: ../../../doc/en/changelog.rst:1486
msgid ""
"`#6057 <https://github.com/pytest-dev/pytest/issues/6057>`_: Added "
"tolerances to complex values when printing ``pytest.approx``."
msgstr ""

#: ../../../doc/en/changelog.rst:1488
msgid ""
"For example, ``repr(pytest.approx(3+4j))`` returns ``(3+4j) ± 5e-06 ∠ "
"±180°``. This is polar notation indicating a circle around the expected "
"value, with a radius of 5e-06. For ``approx`` comparisons to return "
"``True``, the actual value should fall within this circle."
msgstr ""

#: ../../../doc/en/changelog.rst:1491
msgid ""
"`#6061 <https://github.com/pytest-dev/pytest/issues/6061>`_: Added the "
"pluginmanager as an argument to ``pytest_addoption`` so that hooks can be "
"invoked when setting up command line options. This is useful for having one "
"plugin communicate things to another plugin, such as default values or which "
"set of command line options to add."
msgstr ""

#: ../../../doc/en/changelog.rst:1501
msgid ""
"`#5061 <https://github.com/pytest-dev/pytest/issues/5061>`_: Use multiple "
"colors with terminal summary statistics."
msgstr ""

#: ../../../doc/en/changelog.rst:1504
msgid ""
"`#5630 <https://github.com/pytest-dev/pytest/issues/5630>`_: Quitting from "
"debuggers is now properly handled in ``doctest`` items."
msgstr ""

#: ../../../doc/en/changelog.rst:1507
msgid ""
"`#5924 <https://github.com/pytest-dev/pytest/issues/5924>`_: Improved "
"verbose diff output with sequences."
msgstr ""

#: ../../../doc/en/changelog.rst:1509
msgid "Before:"
msgstr ""

#: ../../../doc/en/changelog.rst:1513
msgid ""
"E   AssertionError: assert ['version', '...version_info'] == ['version', '..."
"version', ...]\n"
"E     Right contains 3 more items, first extra item: ' '\n"
"E     Full diff:\n"
"E     - ['version', 'version_info', 'sys.version', 'sys.version_info']\n"
"E     + ['version',\n"
"E     +  'version_info',\n"
"E     +  'sys.version',\n"
"E     +  'sys.version_info',\n"
"E     +  ' ',\n"
"E     +  'sys.version',\n"
"E     +  'sys.version_info']"
msgstr ""

#: ../../../doc/en/changelog.rst:1525
msgid "After:"
msgstr ""

#: ../../../doc/en/changelog.rst:1529
msgid ""
"E   AssertionError: assert ['version', '...version_info'] == ['version', '..."
"version', ...]\n"
"E     Right contains 3 more items, first extra item: ' '\n"
"E     Full diff:\n"
"E       [\n"
"E        'version',\n"
"E        'version_info',\n"
"E        'sys.version',\n"
"E        'sys.version_info',\n"
"E     +  ' ',\n"
"E     +  'sys.version',\n"
"E     +  'sys.version_info',\n"
"E       ]"
msgstr ""

#: ../../../doc/en/changelog.rst:1543
msgid ""
"`#5934 <https://github.com/pytest-dev/pytest/issues/5934>`_: ``repr`` of "
"``ExceptionInfo`` objects has been improved to honor the ``__repr__`` method "
"of the underlying exception."
msgstr ""

#: ../../../doc/en/changelog.rst:1545
msgid ""
"`#5936 <https://github.com/pytest-dev/pytest/issues/5936>`_: Display "
"untruncated assertion message with ``-vv``."
msgstr ""

#: ../../../doc/en/changelog.rst:1548
msgid ""
"`#5990 <https://github.com/pytest-dev/pytest/issues/5990>`_: Fixed plurality "
"mismatch in test summary (e.g. display \"1 error\" instead of \"1 errors\")."
msgstr ""

#: ../../../doc/en/changelog.rst:1551
msgid ""
"`#6008 <https://github.com/pytest-dev/pytest/issues/6008>`_: ``Config."
"InvocationParams.args`` is now always a ``tuple`` to better convey that it "
"should be immutable and avoid accidental modifications."
msgstr ""

#: ../../../doc/en/changelog.rst:1555
msgid ""
"`#6023 <https://github.com/pytest-dev/pytest/issues/6023>`_: ``pytest.main`` "
"returns a ``pytest.ExitCode`` instance now, except for when custom exit "
"codes are used (where it returns ``int`` then still)."
msgstr ""

#: ../../../doc/en/changelog.rst:1558
msgid ""
"`#6026 <https://github.com/pytest-dev/pytest/issues/6026>`_: Align prefixes "
"in output of pytester's ``LineMatcher``."
msgstr ""

#: ../../../doc/en/changelog.rst:1561
msgid ""
"`#6059 <https://github.com/pytest-dev/pytest/issues/6059>`_: Collection "
"errors are reported as errors (and not failures like before) in the "
"terminal's short test summary."
msgstr ""

#: ../../../doc/en/changelog.rst:1564
msgid ""
"`#6069 <https://github.com/pytest-dev/pytest/issues/6069>`_: ``pytester."
"spawn`` does not skip/xfail tests on FreeBSD anymore unconditionally."
msgstr ""

#: ../../../doc/en/changelog.rst:1567
msgid ""
"`#6097 <https://github.com/pytest-dev/pytest/issues/6097>`_: The \"[...%]\" "
"indicator in the test summary is now colored according to the final (new) "
"multi-colored line's main color."
msgstr ""

#: ../../../doc/en/changelog.rst:1570
msgid ""
"`#6116 <https://github.com/pytest-dev/pytest/issues/6116>`_: Added ``--co`` "
"as a synonym to ``--collect-only``."
msgstr ""

#: ../../../doc/en/changelog.rst:1573
msgid ""
"`#6148 <https://github.com/pytest-dev/pytest/issues/6148>`_: "
"``atomicwrites`` is now only used on Windows, fixing a performance "
"regression with assertion rewriting on Unix."
msgstr ""

#: ../../../doc/en/changelog.rst:1576
msgid ""
"`#6152 <https://github.com/pytest-dev/pytest/issues/6152>`_: Now "
"parametrization will use the ``__name__`` attribute of any object for the "
"id, if present. Previously it would only use ``__name__`` for functions and "
"classes."
msgstr ""

#: ../../../doc/en/changelog.rst:1579
msgid ""
"`#6176 <https://github.com/pytest-dev/pytest/issues/6176>`_: Improved "
"failure reporting with pytester's ``Hookrecorder.assertoutcome``."
msgstr ""

#: ../../../doc/en/changelog.rst:1582
msgid ""
"`#6181 <https://github.com/pytest-dev/pytest/issues/6181>`_: The reason for "
"a stopped session, e.g. with ``--maxfail`` / ``-x``, now gets reported in "
"the test summary."
msgstr ""

#: ../../../doc/en/changelog.rst:1585
msgid ""
"`#6206 <https://github.com/pytest-dev/pytest/issues/6206>`_: Improved "
"``cache.set`` robustness and performance."
msgstr ""

#: ../../../doc/en/changelog.rst:1592
msgid ""
"`#2049 <https://github.com/pytest-dev/pytest/issues/2049>`_: Fixed ``--setup-"
"plan`` showing inaccurate information about fixture lifetimes."
msgstr ""

#: ../../../doc/en/changelog.rst:1595
msgid ""
"`#2548 <https://github.com/pytest-dev/pytest/issues/2548>`_: Fixed line "
"offset mismatch of skipped tests in terminal summary."
msgstr ""

#: ../../../doc/en/changelog.rst:1598
msgid ""
"`#6039 <https://github.com/pytest-dev/pytest/issues/6039>`_: The "
"``PytestDoctestRunner`` is now properly invalidated when unconfiguring the "
"doctest plugin."
msgstr ""

#: ../../../doc/en/changelog.rst:1600
msgid ""
"This is important when used with ``pytester``'s ``runpytest_inprocess``."
msgstr ""

#: ../../../doc/en/changelog.rst:1603
msgid ""
"`#6047 <https://github.com/pytest-dev/pytest/issues/6047>`_: BaseExceptions "
"are now handled in ``saferepr``, which includes ``pytest.fail.Exception`` "
"etc."
msgstr ""

#: ../../../doc/en/changelog.rst:1606
msgid ""
"`#6074 <https://github.com/pytest-dev/pytest/issues/6074>`_: pytester: fixed "
"order of arguments in ``rm_rf`` warning when cleaning up temporary "
"directories, and do not emit warnings for errors with ``os.open``."
msgstr ""

#: ../../../doc/en/changelog.rst:1609
msgid ""
"`#6189 <https://github.com/pytest-dev/pytest/issues/6189>`_: Fixed result of "
"``getmodpath`` method."
msgstr ""

#: ../../../doc/en/changelog.rst:1616
msgid ""
"`#4901 <https://github.com/pytest-dev/pytest/issues/4901>`_: ``RunResult`` "
"from ``pytester`` now displays the mnemonic of the ``ret`` attribute when it "
"is a valid ``pytest.ExitCode`` value."
msgstr ""

#: ../../../doc/en/changelog.rst:1621
msgid "pytest 5.2.4 (2019-11-15)"
msgstr ""

#: ../../../doc/en/changelog.rst:1626
msgid ""
"`#6194 <https://github.com/pytest-dev/pytest/issues/6194>`_: Fix incorrect "
"discovery of non-test ``__init__.py`` files."
msgstr ""

#: ../../../doc/en/changelog.rst:1629
msgid ""
"`#6197 <https://github.com/pytest-dev/pytest/issues/6197>`_: Revert \"The "
"first test in a package (``__init__.py``) marked with ``@pytest.mark.skip`` "
"is now correctly skipped.\"."
msgstr ""

#: ../../../doc/en/changelog.rst:1633
msgid "pytest 5.2.3 (2019-11-14)"
msgstr ""

#: ../../../doc/en/changelog.rst:1638
msgid ""
"`#5830 <https://github.com/pytest-dev/pytest/issues/5830>`_: The first test "
"in a package (``__init__.py``) marked with ``@pytest.mark.skip`` is now "
"correctly skipped."
msgstr ""

#: ../../../doc/en/changelog.rst:1641
msgid ""
"`#6099 <https://github.com/pytest-dev/pytest/issues/6099>`_: Fix ``--trace`` "
"when used with parametrized functions."
msgstr ""

#: ../../../doc/en/changelog.rst:1644
msgid ""
"`#6183 <https://github.com/pytest-dev/pytest/issues/6183>`_: Using "
"``request`` as a parameter name in ``@pytest.mark.parametrize`` now produces "
"a more user-friendly error."
msgstr ""

#: ../../../doc/en/changelog.rst:1649
msgid "pytest 5.2.2 (2019-10-24)"
msgstr ""

#: ../../../doc/en/changelog.rst:1654
msgid ""
"`#5206 <https://github.com/pytest-dev/pytest/issues/5206>`_: Fix ``--nf`` to "
"not forget about known nodeids with partial test selection."
msgstr ""

#: ../../../doc/en/changelog.rst:1657
msgid ""
"`#5906 <https://github.com/pytest-dev/pytest/issues/5906>`_: Fix crash with "
"``KeyboardInterrupt`` during ``--setup-show``."
msgstr ""

#: ../../../doc/en/changelog.rst:1660
msgid ""
"`#5946 <https://github.com/pytest-dev/pytest/issues/5946>`_: Fixed issue "
"when parametrizing fixtures with numpy arrays (and possibly other sequence-"
"like types)."
msgstr ""

#: ../../../doc/en/changelog.rst:1663
msgid ""
"`#6044 <https://github.com/pytest-dev/pytest/issues/6044>`_: Properly ignore "
"``FileNotFoundError`` exceptions when trying to remove old temporary "
"directories, for instance when multiple processes try to remove the same "
"directory (common with ``pytest-xdist`` for example)."
msgstr ""

#: ../../../doc/en/changelog.rst:1669
msgid "pytest 5.2.1 (2019-10-06)"
msgstr ""

#: ../../../doc/en/changelog.rst:1674 ../../../doc/en/changelog.rst:2247
msgid ""
"`#5902 <https://github.com/pytest-dev/pytest/issues/5902>`_: Fix warnings "
"about deprecated ``cmp`` attribute in ``attrs>=19.2``."
msgstr ""

#: ../../../doc/en/changelog.rst:1678
msgid "pytest 5.2.0 (2019-09-28)"
msgstr ""

#: ../../../doc/en/changelog.rst:1683
msgid ""
"`#1682 <https://github.com/pytest-dev/pytest/issues/1682>`_: Passing "
"arguments to pytest.fixture() as positional arguments is deprecated - pass "
"them as a keyword argument instead."
