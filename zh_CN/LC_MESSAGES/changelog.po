msgstr ""

#: ../../../doc/en/changelog.rst:1759
msgid "pytest 5.1.1 (2019-08-20)"
msgstr ""

#: ../../../doc/en/changelog.rst:1764
msgid ""
"`#5751 <https://github.com/pytest-dev/pytest/issues/5751>`_: Fixed "
