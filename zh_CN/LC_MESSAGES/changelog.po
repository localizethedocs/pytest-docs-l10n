msgid "fix/refine python3 compatibility (thanks Benjamin Peterson)"
msgstr ""

#: ../../../doc/en/changelog.rst:8489
msgid ""
"fixes for making the jython/win32 combination work, note however: "
"jython2.5.1/win32 does not provide a command line launcher, see http://bugs."
