#: ../../../doc/en/changelog.rst:199
msgid ""
"`#1265 <https://github.com/pytest-dev/pytest/issues/1265>`_: Added an "
"``__str__`` implementation to the :class:`~pytest.pytester.LineMatcher` "
"class which is returned from ``pytester.run_pytest().stdout`` and similar. "
"It returns the entire output, like the existing ``str()`` method."
msgstr ""

#: ../../../doc/en/changelog.rst:202
msgid ""
"`#2044 <https://github.com/pytest-dev/pytest/issues/2044>`_: Verbose mode "
"now shows the reason that a test was skipped in the test's terminal line "
"after the \"SKIPPED\", \"XFAIL\" or \"XPASS\"."
msgstr ""

#: ../../../doc/en/changelog.rst:205
msgid ""
"`#7469 <https://github.com/pytest-dev/pytest/issues/7469>`_ The types of "
"builtin pytest fixtures are now exported so they may be used in type "
"annotations of test functions. The newly-exported types are:"
msgstr ""

#: ../../../doc/en/changelog.rst:208
msgid "``pytest.FixtureRequest`` for the :fixture:`request` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:209
msgid "``pytest.Cache`` for the :fixture:`cache` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:210
msgid ""
"``pytest.CaptureFixture[str]`` for the :fixture:`capfd` and :fixture:"
"`capsys` fixtures."
msgstr ""

#: ../../../doc/en/changelog.rst:211
msgid ""
"``pytest.CaptureFixture[bytes]`` for the :fixture:`capfdbinary` and :fixture:"
"`capsysbinary` fixtures."
msgstr ""

#: ../../../doc/en/changelog.rst:212
msgid "``pytest.LogCaptureFixture`` for the :fixture:`caplog` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:213
msgid "``pytest.Pytester`` for the :fixture:`pytester` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:214
msgid "``pytest.Testdir`` for the :fixture:`testdir` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:215
msgid "``pytest.TempdirFactory`` for the :fixture:`tmpdir_factory` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:216
msgid "``pytest.TempPathFactory`` for the :fixture:`tmp_path_factory` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:217
msgid "``pytest.MonkeyPatch`` for the :fixture:`monkeypatch` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:218
msgid "``pytest.WarningsRecorder`` for the :fixture:`recwarn` fixture."
msgstr ""

#: ../../../doc/en/changelog.rst:220
msgid ""
"Constructing them is not supported (except for `MonkeyPatch`); they are only "
"meant for use in type annotations. Doing so will emit a deprecation warning, "
"and may become a hard-error in pytest 7.0."
msgstr ""

#: ../../../doc/en/changelog.rst:223
msgid ""
"Subclassing them is also not supported. This is not currently enforced at "
"runtime, but is detected by type-checkers such as mypy."
msgstr ""

#: ../../../doc/en/changelog.rst:226
msgid ""
"`#7527 <https://github.com/pytest-dev/pytest/issues/7527>`_: When a "
"comparison between :func:`namedtuple <collections.namedtuple>` instances of "
"the same type fails, pytest now shows the differing field names (possibly "
"nested) instead of their indexes."
msgstr ""

#: ../../../doc/en/changelog.rst:229
msgid ""
"`#7615 <https://github.com/pytest-dev/pytest/issues/7615>`_: :meth:`Node."
"warn <_pytest.nodes.Node.warn>` now permits any subclass of :class:"
"`Warning`, not just :class:`PytestWarning <pytest.PytestWarning>`."
msgstr ""

#: ../../../doc/en/changelog.rst:232
msgid ""
"`#7701 <https://github.com/pytest-dev/pytest/issues/7701>`_: Improved "
"reporting when using ``--collected-only``. It will now show the number of "
"collected tests in the summary stats."
msgstr ""

#: ../../../doc/en/changelog.rst:235
msgid ""
"`#7710 <https://github.com/pytest-dev/pytest/issues/7710>`_: Use strict "
"equality comparison for non-numeric types in :func:`pytest.approx` instead "
"of raising :class:`TypeError`."
msgstr ""

#: ../../../doc/en/changelog.rst:238
msgid ""
"This was the undocumented behavior before 3.7, but is now officially a "
"supported feature."
msgstr ""

#: ../../../doc/en/changelog.rst:241
msgid ""
"`#7938 <https://github.com/pytest-dev/pytest/issues/7938>`_: New ``--sw-"
"skip`` argument which is a shorthand for ``--stepwise-skip``."
msgstr ""

#: ../../../doc/en/changelog.rst:244
msgid ""
"`#8023 <https://github.com/pytest-dev/pytest/issues/8023>`_: Added "
"``'node_modules'`` to default value for :confval:`norecursedirs`."
msgstr ""

#: ../../../doc/en/changelog.rst:247
msgid ""
"`#8032 <https://github.com/pytest-dev/pytest/issues/8032>`_: :meth:"
"`doClassCleanups <unittest.TestCase.doClassCleanups>` (introduced in :mod:"
"`unittest` in Python and 3.8) is now called appropriately."
msgstr ""

#: ../../../doc/en/changelog.rst:254
msgid ""
"`#4824 <https://github.com/pytest-dev/pytest/issues/4824>`_: Fixed quadratic "
"behavior and improved performance of collection of items using autouse "
"fixtures and xunit fixtures."
msgstr ""

#: ../../../doc/en/changelog.rst:257 ../../../doc/en/changelog.rst:308
msgid ""
"`#7758 <https://github.com/pytest-dev/pytest/issues/7758>`_: Fixed an issue "
"where some files in packages are getting lost from ``--lf`` even though they "
"contain tests that failed. Regressed in pytest 5.4.0."
msgstr ""

#: ../../../doc/en/changelog.rst:260
msgid ""
"`#7911 <https://github.com/pytest-dev/pytest/issues/7911>`_: Directories "
"created by by :fixture:`tmp_path` and :fixture:`tmpdir` are now considered "
"stale after 3 days without modification (previous value was 3 hours) to "
"avoid deleting directories still in use in long running test suites."
msgstr ""

#: ../../../doc/en/changelog.rst:263
msgid ""
"`#7913 <https://github.com/pytest-dev/pytest/issues/7913>`_: Fixed a crash "
"or hang in :meth:`pytester.spawn <_pytest.pytester.Pytester.spawn>` when "
"the :mod:`readline` module is involved."
msgstr ""

#: ../../../doc/en/changelog.rst:266
msgid ""
"`#7951 <https://github.com/pytest-dev/pytest/issues/7951>`_: Fixed handling "
"of recursive symlinks when collecting tests."
msgstr ""

#: ../../../doc/en/changelog.rst:269
msgid ""
"`#7981 <https://github.com/pytest-dev/pytest/issues/7981>`_: Fixed symlinked "
"directories not being followed during collection. Regressed in pytest 6.1.0."
msgstr ""

#: ../../../doc/en/changelog.rst:272
msgid ""
"`#8016 <https://github.com/pytest-dev/pytest/issues/8016>`_: Fixed only one "
"doctest being collected when using ``pytest --doctest-modules path/to/an/"
"__init__.py``."
msgstr ""

#: ../../../doc/en/changelog.rst:277 ../../../doc/en/changelog.rst:316
#: ../../../doc/en/changelog.rst:464 ../../../doc/en/changelog.rst:604
#: ../../../doc/en/changelog.rst:987 ../../../doc/en/changelog.rst:1296
