msgid ""
"fix assertion rewriting on files with windows newlines on some Python "
"versions"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:28
msgid ""
"refine test discovery by package/module name (--pyargs), thanks Florian Mayer"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:29
msgid "fix issue69 / assertion rewriting fixed on some boolean operations"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:30
msgid "fix issue68 / packages now work with assertion rewriting"
msgstr ""

