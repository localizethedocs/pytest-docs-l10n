#: ../../../doc/en/announce/release-2.1.2.rst:2
msgid "py.test 2.1.2: bug fixes and fixes for jython"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:4
msgid ""
"pytest-2.1.2 is a minor backward compatible maintenance release of the "
"popular py.test testing tool.  pytest is commonly used for unit, functional- "
"and integration testing.  See extensive docs with examples here:"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:9
msgid "http://pytest.org/"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:11
msgid ""
"Most bug fixes address remaining issues with the perfected assertions "
"introduced in the 2.1 series - many thanks to the bug reporters and to "
"Benjamin Peterson for helping to fix them.  pytest should also work better "
"with Jython-2.5.1 (and Jython trunk)."
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:16
msgid "If you want to install or upgrade pytest, just type one of::"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:18
msgid ""
"pip install -U pytest # or\n"
"easy_install -U pytest"
msgstr ""

#: ../../../doc/en/announce/release-2.1.2.rst:21
msgid "best, holger krekel / https://merlinux.eu/"
msgstr ""

