#: ../../../doc/en/example/markers.rst:5
msgid "Working with custom markers"
msgstr ""

#: ../../../doc/en/example/markers.rst:7
msgid "Here are some examples using the :ref:`mark` mechanism."
msgstr ""

#: ../../../doc/en/example/markers.rst:12
msgid "Marking test functions and selecting them for a run"
msgstr ""

#: ../../../doc/en/example/markers.rst:14
msgid "You can \"mark\" a test function with custom metadata like this:"
msgstr ""

#: ../../../doc/en/example/markers.rst:16
msgid ""
"# content of test_server.py\n"
"\n"
"import pytest\n"
"\n"
"\n"
"@pytest.mark.webtest\n"
"def test_send_http():\n"
"    pass  # perform some webtest test for your app\n"
"\n"
"\n"
"@pytest.mark.device(serial=\"123\")\n"
"def test_something_quick():\n"
"    pass\n"
"\n"
"\n"
"@pytest.mark.device(serial=\"abc\")\n"
"def test_another():\n"
"    pass\n"
"\n"
"\n"
"class TestClass:\n"
"    def test_method(self):\n"
"        pass"
msgstr ""

#: ../../../doc/en/example/markers.rst:44
msgid ""
"You can then restrict a test run to only run tests marked with ``webtest``:"
msgstr ""

#: ../../../doc/en/example/markers.rst:46
msgid ""
"$ pytest -v -m webtest\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-9.x.y, pluggy-1.x.y -- $PYTHON_PREFIX/"
"bin/python\n"
"cachedir: .pytest_cache\n"
"rootdir: /home/sweet/project\n"
"collecting ... collected 4 items / 3 deselected / 1 selected\n"
"\n"
"test_server.py::test_send_http PASSED                                [100%]\n"
"\n"
"===================== 1 passed, 3 deselected in 0.12s ======================"
msgstr ""

#: ../../../doc/en/example/markers.rst:59
msgid "Or the inverse, running all tests except the webtest ones:"
msgstr ""

#: ../../../doc/en/example/markers.rst:61
msgid ""
"$ pytest -v -m \"not webtest\"\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-9.x.y, pluggy-1.x.y -- $PYTHON_PREFIX/"
"bin/python\n"
"cachedir: .pytest_cache\n"
"rootdir: /home/sweet/project\n"
"collecting ... collected 4 items / 1 deselected / 3 selected\n"
"\n"
"test_server.py::test_something_quick PASSED                          [ 33%]\n"
"test_server.py::test_another PASSED                                  [ 66%]\n"
"test_server.py::TestClass::test_method PASSED                        [100%]\n"
"\n"
"===================== 3 passed, 1 deselected in 0.12s ======================"
msgstr ""

#: ../../../doc/en/example/markers.rst:78
msgid ""
"Additionally, you can restrict a test run to only run tests matching one or "
"multiple marker keyword arguments, e.g. to run only tests marked with "
"``device`` and the specific ``serial=\"123\"``:"
msgstr ""

#: ../../../doc/en/example/markers.rst:81
msgid ""
"$ pytest -v -m \"device(serial='123')\"\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-9.x.y, pluggy-1.x.y -- $PYTHON_PREFIX/"
"bin/python\n"
"cachedir: .pytest_cache\n"
"rootdir: /home/sweet/project\n"
"collecting ... collected 4 items / 3 deselected / 1 selected\n"
"\n"
"test_server.py::test_something_quick PASSED                          [100%]\n"
"\n"
"===================== 1 passed, 3 deselected in 0.12s ======================"
msgstr ""

#: ../../../doc/en/example/markers.rst:94
msgid "Only keyword argument matching is supported in marker expressions."
msgstr ""

#: ../../../doc/en/example/markers.rst:96
msgid ""
"Only :class:`int`, (unescaped) :class:`str`, :class:`bool` & :data:`None` "
"values are supported in marker expressions."
msgstr ""

#: ../../../doc/en/example/markers.rst:99
msgid "Selecting tests based on their node ID"
msgstr ""

#: ../../../doc/en/example/markers.rst:101
msgid ""
"You can provide one or more :ref:`node IDs <node-id>` as positional "
"arguments to select only specified tests. This makes it easy to select tests "
"based on their module, class, method, or function name:"
msgstr ""

#: ../../../doc/en/example/markers.rst:105
msgid ""
"$ pytest -v test_server.py::TestClass::test_method\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-9.x.y, pluggy-1.x.y -- $PYTHON_PREFIX/"
"bin/python\n"
"cachedir: .pytest_cache\n"
"rootdir: /home/sweet/project\n"
"collecting ... collected 1 item\n"
"\n"
"test_server.py::TestClass::test_method PASSED                        [100%]\n"
"\n"
"============================ 1 passed in 0.12s ============================="
msgstr ""

#: ../../../doc/en/example/markers.rst:118
msgid "You can also select on the class:"
msgstr ""

#: ../../../doc/en/example/markers.rst:120
msgid ""
"$ pytest -v test_server.py::TestClass\n"
"=========================== test session starts "
"============================\n"
"platform linux -- Python 3.x.y, pytest-9.x.y, pluggy-1.x.y -- $PYTHON_PREFIX/"
