#: ../../../doc/en/reference/customize.rst:291
msgid "Syntax highlighting theme customization"
msgstr ""

#: ../../../doc/en/reference/customize.rst:293
msgid ""
"The syntax highlighting themes used by pytest can be customized using two "
"environment variables:"
msgstr ""

