#: ../../../doc/en/deprecations.rst:383
msgid "``yield`` tests raise a collection error."
msgstr ""

#: ../../../doc/en/deprecations.rst:385
msgid ""
"pytest no longer supports ``yield``-style tests, where a test function "
"actually ``yield`` functions and values that are then turned into proper "
"test methods. Example:"
msgstr ""

#: ../../../doc/en/deprecations.rst:388
msgid ""
"def check(x, y):\n"
"    assert x**x == y\n"
"\n"
"\n"
"def test_squared():\n"
"    yield check, 2, 4\n"
"    yield check, 3, 9"
msgstr ""

#: ../../../doc/en/deprecations.rst:398
msgid "This would result in two actual test functions being generated."
msgstr ""

#: ../../../doc/en/deprecations.rst:400
msgid ""
"This form of test function doesn't support fixtures properly, and users "
"should switch to ``pytest.mark.parametrize``:"
msgstr ""

#: ../../../doc/en/deprecations.rst:402
msgid ""
"@pytest.mark.parametrize(\"x, y\", [(2, 4), (3, 9)])\n"
"def test_squared(x, y):\n"
"    assert x**x == y"
msgstr ""

